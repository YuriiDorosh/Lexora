# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=StrongDBPass_123

# ============================================================
# Nginx
# ============================================================
NGINX_PORT=5433

# ============================================================
# RabbitMQ
# Used by: RabbitMQ container, Odoo custom code (M3+),
#          and all four worker services (M3-M6).
# Change RABBITMQ_PASS to something strong before deploying.
# ============================================================
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/
# Internal Docker hostname — do not change unless you rename the container.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# ============================================================
# Redis
# Used by: Odoo custom code for PvP state (M10+),
#          and worker services for idempotency checks (M3+).
# No password configured for dev. Add requirepass for production.
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================
# LLM enrichment service (M4b)
# Real CPU-only inference via llama-cpp-python on a GGUF model.
# Defaults are sized for an 8 GiB target server (ADR-027).
#
# Opt-in to larger model on hosts with >=16 GiB RAM headroom:
#   LLM_MODEL_REPO=Qwen/Qwen2.5-3B-Instruct-GGUF
#   LLM_MODEL_FILENAME=qwen2.5-3b-instruct-q4_k_m.gguf
#
# LLM_AUTO_DOWNLOAD=0 disables first-start HF download for air-gapped
# installs; operator must pre-seed the llm_models volume.
# ============================================================
LLM_MODEL_REPO=Qwen/Qwen2.5-1.5B-Instruct-GGUF
LLM_MODEL_FILENAME=qwen2.5-1.5b-instruct-q4_k_m.gguf
LLM_MODEL_DIR=/models
LLM_N_CTX=2048
LLM_N_THREADS=0
LLM_MAX_TOKENS=512
LLM_AUTO_DOWNLOAD=1

# ============================================================
# Translation service (M4c)
# Online free-API translation via deep_translator (ADR-028).
# Default provider: Google Translate (no API key required).
# Fallback provider: MyMemory (auto-used on primary error/timeout).
#
# Restricted-egress networks: if the server cannot reach Google,
# set TRANSLATE_PROVIDER=mymemory as a safer default (MyMemory
# tolerates some firewalled environments) or swap to a paid provider
# (deepl, google_cloud, azure) — all supported by deep_translator
# as a one-line constructor change.
# ============================================================
TRANSLATE_PROVIDER=google
TRANSLATE_FALLBACK_PROVIDER=mymemory
TRANSLATE_TIMEOUT_SECONDS=10

# ============================================================
# Audio service (M6)
# TTS via edge-tts (online, Microsoft Edge free API, no key).
# Fallback TTS: espeak-ng (local system package, lower quality).
# STT via faster-whisper (CPU-only, int8 quantized).
#
# TTS_ENGINE options: edge-tts | espeak-ng
# Air-gapped networks: set TTS_ENGINE=espeak-ng (offline, lower quality).
# WHISPER_MODEL options: tiny (~75 MB) | base (~145 MB) | small (~461 MB)
# AUDIO_TRANSCRIPTION_ENABLED=0 to disable STT entirely (saves ~300 MB RAM).
# ============================================================
TTS_ENGINE=edge-tts
TTS_FALLBACK_ENGINE=espeak-ng
WHISPER_MODEL=base
AUDIO_TRANSCRIPTION_ENABLED=1
AUDIO_MAX_DURATION_SECONDS=300

# ============================================================
# AI Mentor / Helpdesk RAG service (M26)
#
# LLM model — same default as the existing llm-service (Qwen2.5-1.5B Q4_K_M,
# ~1.2 GiB resident). Both services share the same HuggingFace cache volume
# if desired, but ai_mentor uses a dedicated ai_mentor_models volume.
#
# Upgrade path: set to Phi-3 Mini 3.8B (~2.2 GiB) on hosts with ≥12 GiB RAM:
#   AI_LLM_MODEL_REPO=microsoft/Phi-3-mini-4k-instruct-gguf
#   AI_LLM_MODEL_FILENAME=Phi-3-mini-4k-instruct-q4.gguf
#
# Embedding model: BAAI/bge-small-en-v1.5 (33 MB ONNX, 384-dim).
# CPU-only — no torch or GPU required (fastembed ONNX backend).
#
# AI_LLM_AUTO_DOWNLOAD=0 for air-gapped pre-seeded volumes.
# ============================================================
AI_LLM_MODEL_REPO=Qwen/Qwen2.5-1.5B-Instruct-GGUF
AI_LLM_MODEL_FILENAME=qwen2.5-1.5b-instruct-q4_k_m.gguf
AI_LLM_N_CTX=2048
AI_LLM_N_THREADS=0
AI_LLM_MAX_TOKENS=400
AI_LLM_AUTO_DOWNLOAD=1
AI_EMBED_MODEL=BAAI/bge-small-en-v1.5
AI_EMBED_DIM=384
AI_RAG_TOP_K=5
AI_RAG_MIN_SCORE=0.30
