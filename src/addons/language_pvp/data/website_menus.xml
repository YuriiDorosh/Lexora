<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate=0 so parent_id re-parenting applies on every update run -->
    <data noupdate="0">

        <!-- Arena — child of Tools group (language_portal) -->
        <record id="menu_navbar_arena" model="website.menu">
            <field name="name">Arena</field>
            <field name="url">/my/arena</field>
            <field name="parent_id" ref="language_portal.menu_tools_group"/>
            <field name="sequence">30</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

    </data>
</odoo>
