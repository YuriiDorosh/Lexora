<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================== -->
    <!-- Arena Lobby  /my/arena                                         -->
    <!-- ============================================================== -->
    <template id="portal_arena_lobby" name="PvP Arena Lobby">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <div class="container py-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h2 class="mb-0">⚔ Arena</h2>
                    <button type="button" class="btn btn-primary"
                            data-bs-toggle="modal" data-bs-target="#newChallengeModal">
                        + New Challenge
                    </button>
                </div>

                <!-- Error banner -->
                <t t-if="request.params.get('error')">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <t t-esc="request.params.get('error')"/>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"/>
                    </div>
                </t>

                <!-- Open Challenges -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Open Challenges</h5>
                    </div>
                    <div class="card-body p-0">
                        <t t-if="open_challenges">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Challenger</th>
                                        <th>Practice</th>
                                        <th>Rounds</th>
                                        <th>XP Staked</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="open_challenges" t-as="duel">
                                        <tr>
                                            <td><t t-esc="duel.challenger_id.name"/></td>
                                            <td>
                                                <span class="badge bg-info text-dark">
                                                    <t t-esc="lang_names.get(duel.practice_language, duel.practice_language)"/>
                                                </span>
                                                ↔
                                                <span class="badge bg-secondary">
                                                    <t t-esc="lang_names.get(duel.native_language, duel.native_language)"/>
                                                </span>
                                            </td>
                                            <td><t t-esc="duel.rounds_total"/></td>
                                            <td>
                                                <span class="badge bg-warning text-dark">
                                                    <t t-esc="duel.xp_staked"/> XP
                                                </span>
                                            </td>
                                            <td>
                                                <form t-attf-action="/my/arena/#{duel.id}/join" method="post">
                                                    <input type="hidden" name="csrf_token"
                                                           t-att-value="request.csrf_token()"/>
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        Accept
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <div class="text-center text-muted py-4">
                                No open challenges right now. Create one!
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Your Active Duels -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Your Active Duels</h5>
                    </div>
                    <div class="card-body p-0">
                        <t t-if="active_duels">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Opponent</th>
                                        <th>Languages</th>
                                        <th>Status</th>
                                        <th>Progress</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="active_duels" t-as="duel">
                                        <t t-set="_opponent"
                                           t-value="duel.opponent_id if duel.challenger_id.id != uid else duel.challenger_id"/>
                                        <tr>
                                            <td>
                                                <t t-if="duel.state == 'open' and duel.challenger_id.id == uid">
                                                    <em class="text-muted">Waiting for opponent…</em>
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="_opponent.name"/>
                                                </t>
                                            </td>
                                            <td>
                                                <span class="badge bg-info text-dark">
                                                    <t t-esc="lang_names.get(duel.practice_language, duel.practice_language)"/>
                                                </span>
                                            </td>
                                            <td>
                                                <span t-att-class="'badge ' + ('bg-warning text-dark' if duel.state == 'open' else 'bg-primary text-white')">
                                                    <t t-esc="duel.state.title()"/>
                                                </span>
                                            </td>
                                            <td>
                                                <t t-set="_my_rounds" t-value="duel._rounds_submitted_by(uid)"/>
                                                <t t-esc="_my_rounds"/> / <t t-esc="duel.rounds_total"/>
                                            </td>
                                            <td>
                                                <a t-attf-href="/my/arena/#{duel.id}"
                                                   class="btn btn-sm btn-outline-primary">
                                                    Play →
                                                </a>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <div class="text-center text-muted py-4">No active duels.</div>
                        </t>
                    </div>
                </div>

                <!-- Recent History -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Recent Battle History</h5>
                    </div>
                    <div class="card-body p-0">
                        <t t-if="recent_history">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Opponent</th>
                                        <th>Languages</th>
                                        <th>Score</th>
                                        <th>Result</th>
                                        <th>XP</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="recent_history" t-as="duel">
                                        <t t-set="_is_challenger" t-value="duel.challenger_id.id == uid"/>
                                        <t t-set="_opponent"
                                           t-value="duel.opponent_id if _is_challenger else duel.challenger_id"/>
                                        <t t-set="_my_score"
                                           t-value="duel.challenger_score if _is_challenger else duel.opponent_score"/>
                                        <t t-set="_their_score"
                                           t-value="duel.opponent_score if _is_challenger else duel.challenger_score"/>
                                        <t t-set="_won" t-value="duel.winner_id and duel.winner_id.id == uid"/>
                                        <t t-set="_draw" t-value="not duel.winner_id"/>
                                        <tr>
                                            <td><t t-esc="_opponent.name if _opponent else 'Unknown'"/></td>
                                            <td>
                                                <span class="badge bg-secondary">
                                                    <t t-esc="lang_names.get(duel.practice_language, duel.practice_language)"/>
                                                </span>
                                            </td>
                                            <td><t t-esc="_my_score"/> – <t t-esc="_their_score"/></td>
                                            <td>
                                                <span t-att-class="'badge ' + ('bg-success' if _won else ('bg-secondary' if _draw else 'bg-danger'))">
                                                    <t t-if="_won">Win</t>
                                                    <t t-elif="_draw">Draw</t>
                                                    <t t-else="">Loss</t>
                                                </span>
                                            </td>
                                            <td>
                                                <t t-if="_won">
                                                    <span class="text-success">+<t t-esc="duel.xp_staked"/> XP</span>
                                                </t>
                                                <t t-elif="_draw">
                                                    <span class="text-muted">—</span>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-danger">-<t t-esc="duel.xp_staked"/> XP</span>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <div class="text-center text-muted py-4">No battles yet.</div>
                        </t>
                    </div>
                </div>

            </div>

            <!-- New Challenge Modal -->
            <div class="modal fade" id="newChallengeModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form action="/my/arena/new" method="post">
                            <input type="hidden" name="csrf_token"
                                   t-att-value="request.csrf_token()"/>
                            <div class="modal-header">
                                <h5 class="modal-title">New Challenge</h5>
                                <button type="button" class="btn-close"
                                        data-bs-dismiss="modal"/>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label">Practice Language</label>
                                    <select name="practice_language" class="form-select" required="required">
                                        <t t-foreach="languages" t-as="lng">
                                            <option t-att-value="lng[0]"><t t-esc="lng[1]"/></option>
                                        </t>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Native Language</label>
                                    <select name="native_language" class="form-select" required="required">
                                        <t t-foreach="languages" t-as="lng">
                                            <option t-att-value="lng[0]"><t t-esc="lng[1]"/></option>
                                        </t>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Rounds</label>
                                    <select name="rounds_total" class="form-select">
                                        <option value="5">5</option>
                                        <option value="10" selected="selected">10</option>
                                        <option value="20">20</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">XP Staked</label>
                                    <input type="number" name="xp_staked" class="form-control"
                                           value="10" min="0" max="100"/>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary"
                                        data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Create Challenge</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </t>
    </template>

    <!-- ============================================================== -->
    <!-- Duel Detail  /my/arena/<id>                                    -->
    <!-- ============================================================== -->
    <template id="portal_arena_duel" name="Duel Detail">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <div class="container py-4">
                <div class="d-flex align-items-center mb-3">
                    <a href="/my/arena" class="btn btn-outline-secondary btn-sm me-3">← Arena</a>
                    <h3 class="mb-0">Duel #<t t-esc="duel.id"/></h3>
                    <span t-att-class="'badge ms-3 ' + ('bg-warning text-dark' if duel.state == 'open' else ('bg-primary' if duel.state == 'ongoing' else 'bg-success'))">
                        <t t-esc="duel.state.title()"/>
                    </span>
                </div>

                <!-- Metadata card -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-6 col-md-3">
                                <small class="text-muted d-block">Challenger</small>
                                <strong><t t-esc="duel.challenger_id.name"/></strong>
                            </div>
                            <div class="col-6 col-md-3">
                                <small class="text-muted d-block">Opponent</small>
                                <strong>
                                    <t t-if="duel.opponent_id">
                                        <t t-esc="duel.opponent_id.name"/>
                                    </t>
                                    <t t-else="">
                                        <em class="text-muted">Open</em>
                                    </t>
                                </strong>
                            </div>
                            <div class="col-6 col-md-3">
                                <small class="text-muted d-block">Languages</small>
                                <span class="badge bg-info text-dark me-1">
                                    <t t-esc="lang_names.get(duel.practice_language, duel.practice_language)"/>
                                </span>
                                ↔
                                <span class="badge bg-secondary ms-1">
                                    <t t-esc="lang_names.get(duel.native_language, duel.native_language)"/>
                                </span>
                            </div>
                            <div class="col-6 col-md-3">
                                <small class="text-muted d-block">XP Staked</small>
                                <span class="badge bg-warning text-dark">
                                    <t t-esc="duel.xp_staked"/> XP
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- State: open, waiting for opponent to join -->
                <t t-if="duel.state == 'open' and duel.challenger_id.id != uid">
                    <div class="card border-0 shadow-sm text-center py-5 mb-4">
                        <div class="card-body">
                            <h4>Accept this challenge?</h4>
                            <p class="text-muted">
                                <t t-esc="duel.challenger_id.name"/> challenges you to
                                <strong><t t-esc="duel.rounds_total"/> rounds</strong> of
                                <strong><t t-esc="lang_names.get(duel.practice_language, duel.practice_language)"/></strong>.
                            </p>
                            <form t-attf-action="/my/arena/#{duel.id}/join" method="post">
                                <input type="hidden" name="csrf_token"
                                       t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-success btn-lg">
                                    Accept Challenge
                                </button>
                            </form>
                        </div>
                    </div>
                </t>

                <t t-elif="duel.state == 'open' and duel.challenger_id.id == uid">
                    <div class="alert alert-info">
                        Your challenge is open. Share the link or wait for someone to join.
                    </div>
                </t>

                <!-- State: ongoing — show play card if rounds remain -->
                <t t-if="duel.state == 'ongoing'">
                    <t t-set="_submitted" t-value="duel._rounds_submitted_by(uid)"/>
                    <t t-if="_submitted >= duel.rounds_total">
                        <div class="alert alert-success">
                            You have submitted all <t t-esc="duel.rounds_total"/> rounds.
                            Waiting for your opponent to finish…
                        </div>
                    </t>
                    <t t-elif="current_entry">
                        <div class="card border-primary shadow mb-4">
                            <div class="card-header bg-primary text-white">
                                <strong>Round <t t-esc="round_number"/> of <t t-esc="duel.rounds_total"/></strong>
                            </div>
                            <div class="card-body text-center py-5">
                                <p class="text-muted mb-2">Translate this word:</p>
                                <h2 class="display-5 mb-4">
                                    <t t-esc="current_entry.source_text"/>
                                </h2>
                                <p class="text-muted mb-4">
                                    (<t t-esc="lang_names.get(current_entry.source_language, current_entry.source_language)"/>)
                                </p>
                                <form t-attf-action="/my/arena/#{duel.id}/answer" method="post">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="entry_id"
                                           t-att-value="current_entry.id"/>
                                    <div class="d-flex justify-content-center gap-2">
                                        <input type="text" name="answer_given"
                                               class="form-control w-auto"
                                               placeholder="Your translation…"
                                               autofocus="autofocus"
                                               required="required"/>
                                        <button type="submit" class="btn btn-primary">
                                            Submit
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </t>
                </t>

                <!-- State: finished — show results table -->
                <t t-if="duel.state == 'finished'">
                    <div t-att-class="'alert alert-' + ('success' if duel.winner_id and duel.winner_id.id == uid else ('secondary' if not duel.winner_id else 'danger'))">
                        <t t-if="duel.winner_id and duel.winner_id.id == uid">
                            You won! +<t t-esc="duel.xp_staked"/> XP
                        </t>
                        <t t-elif="not duel.winner_id">
                            Draw — no XP change.
                        </t>
                        <t t-else="">
                            You lost. -<t t-esc="duel.xp_staked"/> XP
                        </t>
                    </div>

                    <div class="row g-3 mb-4">
                        <!-- Score summary -->
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-body text-center">
                                    <h4>
                                        <t t-esc="duel.challenger_id.name"/>
                                        <span class="badge bg-primary mx-2">
                                            <t t-esc="duel.challenger_score"/>
                                        </span>
                                        vs
                                        <span class="badge bg-primary mx-2">
                                            <t t-esc="duel.opponent_score"/>
                                        </span>
                                        <t t-esc="duel.opponent_id.name if duel.opponent_id else 'Unknown'"/>
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <!-- Challenger rounds -->
                        <t t-if="challenger_lines">
                            <div class="col-md-6">
                                <h6 class="text-muted"><t t-esc="duel.challenger_id.name"/>'s rounds</h6>
                                <table class="table table-sm">
                                    <thead><tr><th>#</th><th>Word</th><th>Answer</th><th></th></tr></thead>
                                    <tbody>
                                        <t t-foreach="challenger_lines" t-as="line">
                                            <tr t-att-class="'table-success' if line.correct else 'table-danger'">
                                                <td><t t-esc="line.round_number"/></td>
                                                <td><t t-esc="line.entry_id.source_text"/></td>
                                                <td><t t-esc="line.answer_given"/></td>
                                                <td>
                                                    <t t-if="line.correct">✓</t>
                                                    <t t-else="">✗</t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <!-- Opponent rounds -->
                        <t t-if="opponent_lines">
                            <div class="col-md-6">
                                <h6 class="text-muted"><t t-esc="duel.opponent_id.name"/>'s rounds</h6>
                                <table class="table table-sm">
                                    <thead><tr><th>#</th><th>Word</th><th>Answer</th><th></th></tr></thead>
                                    <tbody>
                                        <t t-foreach="opponent_lines" t-as="line">
                                            <tr t-att-class="'table-success' if line.correct else 'table-danger'">
                                                <td><t t-esc="line.round_number"/></td>
                                                <td><t t-esc="line.entry_id.source_text"/></td>
                                                <td><t t-esc="line.answer_given"/></td>
                                                <td>
                                                    <t t-if="line.correct">✓</t>
                                                    <t t-else="">✗</t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>
                </t>

            </div>
        </t>
    </template>

    <!-- Portal home widget: active duel count -->
    <template id="portal_my_home_arena" name="Portal Home: Arena"
              inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[hasclass('o_portal_my_home')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Arena Duels</t>
                <t t-set="url">/my/arena</t>
                <t t-set="count" t-value="arena_active_count"/>
                <t t-set="placeholder_count">'arena_active_count'</t>
            </t>
        </xpath>
    </template>

</odoo>
