<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron: consume Anki import result events from RabbitMQ.
             Runs every minute.  Drains anki.import.completed and
             anki.import.failed queues, creates language.entry records,
             and updates language.anki.job with counts and details_log.
             noupdate="1" so admins can tune the interval without reset on upgrade. -->
        <record id="cron_consume_anki_results" model="ir.cron">
            <field name="name">Lexora: Consume Anki Import Results</field>
            <field name="model_id" ref="language_anki_jobs.model_language_anki_job"/>
            <field name="state">code</field>
            <field name="code">model.action_consume_results()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>
