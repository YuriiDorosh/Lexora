<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Inject the Audio / Pronunciation section into the entry detail page.
        Injection point: BEFORE the <hr class="my-3"/> separator, so the order is:
          Translations → Audio → hr → Enrichment → Media Links.

        Template is self-contained: all audio state is derived from entry.audio_ids
        using t-set + inline lambdas — no new controller variables required.
        This avoids the Python hot-reload issue discovered in M5c (TASKS.md).

        Upload UX: <input type="file" capture="microphone"> + auto-submit JS
        (instead of MediaRecorder API). Rationale: the OS handles recording
        natively; the file arrives as standard multipart; cross-browser compatible;
        ~4 lines of JS required vs. complex blob assembly for MediaRecorder.
    -->
    <template id="portal_entry_audio_section"
              inherit_id="language_words.portal_vocabulary_detail"
              name="Entry Detail — Audio Section">

        <xpath expr="//hr[contains(@class,'my-3')]" position="before">

            <!-- Derive audio state inline so no controller change is needed. -->
            <t t-set="_rec" t-value="entry.audio_ids.filtered(lambda a: a.audio_type == 'recorded' and a.language == entry.source_language)"/>
            <t t-set="_rec" t-value="_rec[0] if _rec else False"/>
            <t t-set="_gen" t-value="entry.audio_ids.filtered(lambda a: a.audio_type == 'generated' and a.language == entry.source_language)"/>
            <t t-set="_gen" t-value="_gen[0] if _gen else False"/>

            <div class="mb-3">
                <h6 class="text-uppercase text-muted small fw-bold mb-2">Pronunciation</h6>

                <!-- ═══════════════════════════════════════════════
                     A) User recording
                ═══════════════════════════════════════════════ -->
                <div class="mb-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="small fw-medium text-secondary">Your recording</span>
                        <t t-if="_rec and _rec.status == 'completed' and _rec.attachment_id">
                            <span class="badge bg-success" style="font-size:0.65rem">✓ saved</span>
                        </t>
                    </div>

                    <!-- Existing recording player -->
                    <t t-if="_rec and _rec.status == 'completed' and _rec.attachment_id">
                        <audio controls="controls" class="w-100 mb-2"
                               t-att-src="'/my/audio/%d/stream' % _rec.id"
                               preload="none"/>

                        <!-- Transcription result -->
                        <t t-if="_rec.transcription">
                            <blockquote class="border-start border-2 border-info ps-3 fst-italic text-muted small mb-2">
                                <t t-esc="_rec.transcription"/>
                            </blockquote>
                        </t>

                        <!-- Transcription trigger -->
                        <t t-if="_rec.transcription_status not in ('processing', 'pending')">
                            <form t-att-action="'/my/audio/transcribe/%d' % _rec.id"
                                  method="post" class="d-inline">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-sm btn-outline-info me-2">
                                    <t t-if="not _rec.transcription">🔍 Check pronunciation</t>
                                    <t t-else="">↺ Re-transcribe</t>
                                </button>
                            </form>
                        </t>
                        <t t-if="_rec.transcription_status in ('processing', 'pending')">
                            <button class="btn btn-sm btn-outline-secondary me-2" disabled="disabled">
                                <span class="spinner-border spinner-border-sm me-1"
                                      role="status" aria-hidden="true"/>
                                Transcribing…
                            </button>
                        </t>
                        <t t-if="_rec.transcription_status == 'failed'">
                            <span class="text-danger small me-2">
                                Transcription failed
                                <t t-if="_rec.transcription_error"> — <t t-esc="_rec.transcription_error"/></t>
                            </span>
                        </t>
                    </t>

                    <!-- Processing / pending state -->
                    <t t-if="_rec and _rec.status in ('processing', 'pending')">
                        <div class="text-muted small mb-2">
                            <span class="spinner-border spinner-border-sm me-1"
                                  role="status" aria-hidden="true"/>
                            Saving recording…
                        </div>
                    </t>

                    <!-- Recording UI — MediaRecorder (primary) + file upload (fallback) -->
                    <div t-att-id="'recording-ui-%d' % entry.id">
                        <!-- MediaRecorder controls -->
                        <button type="button"
                                class="btn btn-sm btn-outline-danger me-1"
                                t-att-id="'record-start-%d' % entry.id">
                            <t t-if="not _rec or _rec.status != 'completed'">🎤 Record</t>
                            <t t-else="">🎤 Re-record</t>
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-danger me-1 d-none"
                                t-att-id="'record-stop-%d' % entry.id">
                            ⬛ Stop
                        </button>
                        <span class="text-muted small"
                              t-att-id="'record-status-%d' % entry.id"></span>

                        <!-- File upload fallback (hidden label trigger) -->
                        <form t-att-action="'/my/audio/upload/%d' % entry.id"
                              method="post"
                              enctype="multipart/form-data"
                              class="d-inline"
                              t-att-id="'audio-upload-form-%d' % entry.id">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="language" t-att-value="entry.source_language"/>
                            <input type="file"
                                   name="audio_file"
                                   accept="audio/*"
                                   class="d-none"
                                   t-att-id="'audio-file-input-%d' % entry.id"/>
                            <label t-att-for="'audio-file-input-%d' % entry.id"
                                   class="btn btn-sm btn-outline-secondary"
                                   title="Upload an existing audio file">
                                📁 Upload file
                            </label>
                        </form>
                    </div>

                    <script>
                    (function() {
                        var eid = <t t-esc="entry.id"/>;
                        var lang = '<t t-esc="entry.source_language"/>';
                        var csrf = '<t t-esc="request.csrf_token()"/>';
                        var uploadUrl = '/my/audio/upload/' + eid;

                        var startBtn  = document.getElementById('record-start-' + eid);
                        var stopBtn   = document.getElementById('record-stop-' + eid);
                        var statusEl  = document.getElementById('record-status-' + eid);
                        var fileInput = document.getElementById('audio-file-input-' + eid);

                        var mediaRecorder = null;
                        var chunks = [];

                        function setStatus(msg) { if (statusEl) statusEl.textContent = msg; }

                        /* File-input fallback: auto-submit on change */
                        if (fileInput) {
                            fileInput.addEventListener('change', function() {
                                fileInput.form.submit();
                            });
                        }

                        if (!startBtn) { return; }

                        startBtn.addEventListener('click', function() {
                            if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                                setStatus('Microphone not supported — use "Upload file" instead.');
                                return;
                            }
                            navigator.mediaDevices.getUserMedia({audio: true, video: false})
                                .then(function(stream) {
                                    chunks = [];
                                    /* Pick a supported MIME type — browsers vary */
                                    var mimeType = '';
                                    var candidates = ['audio/webm;codecs=opus', 'audio/webm', 'audio/ogg'];
                                    for (var i = 0; i &lt; candidates.length; i++) {
                                        if (MediaRecorder.isTypeSupported(candidates[i])) {
                                            mimeType = candidates[i];
                                            break;
                                        }
                                    }
                                    var opts = mimeType ? {mimeType: mimeType} : {};
                                    mediaRecorder = new MediaRecorder(stream, opts);

                                    mediaRecorder.addEventListener('dataavailable', function(e) {
                                        if (e.data &amp;&amp; e.data.size > 0) { chunks.push(e.data); }
                                    });

                                    mediaRecorder.addEventListener('stop', function() {
                                        stream.getTracks().forEach(function(t) { t.stop(); });
                                        var blob = new Blob(chunks, {type: mimeType || 'audio/webm'});
                                        var fd = new FormData();
                                        fd.append('audio_file', blob, 'recording.webm');
                                        fd.append('csrf_token', csrf);
                                        fd.append('language', lang);
                                        setStatus('Uploading…');
                                        fetch(uploadUrl, {method: 'POST', body: fd})
                                            .then(function(r) { return r.json(); })
                                            .then(function(d) {
                                                if (d.status === 'ok') {
                                                    setStatus('Saved! Reloading…');
                                                    window.location.reload();
                                                } else {
                                                    setStatus('Error: ' + (d.message || 'Unknown error'));
                                                }
                                            })
                                            .catch(function(err) {
                                                setStatus('Upload failed: ' + err.message);
                                            });
                                    });

                                    mediaRecorder.start();
                                    startBtn.classList.add('d-none');
                                    stopBtn.classList.remove('d-none');
                                    setStatus('● Recording…');
                                })
                                .catch(function(err) {
                                    setStatus('Mic error: ' + err.message + ' — try "Upload file".');
                                });
                        });

                        stopBtn.addEventListener('click', function() {
                            if (mediaRecorder &amp;&amp; mediaRecorder.state !== 'inactive') {
                                mediaRecorder.stop();
                            }
                            stopBtn.classList.add('d-none');
                            startBtn.classList.remove('d-none');
                            setStatus('Processing…');
                        });
                    })();
                    </script>
                </div>

                <!-- ═══════════════════════════════════════════════
                     B) Generated TTS
                ═══════════════════════════════════════════════ -->
                <div>
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="small fw-medium text-secondary">AI pronunciation</span>
                        <span class="badge bg-secondary" style="font-size:0.65rem">
                            <t t-esc="lang_names.get(entry.source_language, entry.source_language)"/>
                        </span>
                        <t t-if="_gen and _gen.status == 'completed'">
                            <span class="badge bg-success" style="font-size:0.65rem">✓ ready</span>
                        </t>
                    </div>

                    <!-- Completed TTS player -->
                    <t t-if="_gen and _gen.status == 'completed' and _gen.attachment_id">
                        <audio controls="controls" class="w-100 mb-2"
                               t-att-src="'/my/audio/%d/stream' % _gen.id"
                               preload="none"/>
                        <form t-att-action="'/my/audio/generate/%d' % entry.id"
                              method="post" class="d-inline">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="language" t-att-value="entry.source_language"/>
                            <button type="submit" class="btn btn-sm btn-outline-secondary">↺ Regenerate</button>
                        </form>
                    </t>

                    <!-- In-progress TTS -->
                    <t t-if="_gen and _gen.status in ('processing', 'pending')">
                        <div class="text-muted small mb-2">
                            <span class="spinner-border spinner-border-sm me-1"
                                  role="status" aria-hidden="true"/>
                            Generating pronunciation… (results in ~1 min)
                        </div>
                    </t>

                    <!-- Failed TTS -->
                    <t t-if="_gen and _gen.status == 'failed'">
                        <div class="text-danger small mb-1">
                            TTS generation failed
                            <t t-if="_gen.error_message"> — <t t-esc="_gen.error_message"/></t>
                        </div>
                        <form t-att-action="'/my/audio/generate/%d' % entry.id"
                              method="post" class="d-inline">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="language" t-att-value="entry.source_language"/>
                            <button type="submit" class="btn btn-sm btn-outline-warning">↺ Retry</button>
                        </form>
                    </t>

                    <!-- Not yet generated -->
                    <t t-if="not _gen">
                        <form t-att-action="'/my/audio/generate/%d' % entry.id"
                              method="post" class="d-inline">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="language" t-att-value="entry.source_language"/>
                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                🔊 Generate pronunciation
                            </button>
                        </form>
                        <span class="text-muted small ms-2">Powered by edge-tts — ready in ~1 min</span>
                    </t>
                </div>
            </div>

        </xpath>
    </template>
</odoo>
