<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Language Users can only read their own translations (via entry ownership). -->
        <record id="rule_translation_owner_read" model="ir.rule">
            <field name="name">Translation: owner read own entries</field>
            <field name="model_id" ref="model_language_translation"/>
            <field name="domain_force">[('entry_id.owner_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('language_security.group_language_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
