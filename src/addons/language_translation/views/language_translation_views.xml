<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         language.translation — list view
    ============================================================ -->
    <record id="view_language_translation_list" model="ir.ui.view">
        <field name="name">language.translation.list</field>
        <field name="model">language.translation</field>
        <field name="arch" type="xml">
            <list string="Translations" decoration-success="status == 'completed'"
                  decoration-warning="status == 'processing'"
                  decoration-danger="status == 'failed'"
                  decoration-muted="status == 'pending'">
                <field name="entry_id"/>
                <field name="target_language"/>
                <field name="translated_text"/>
                <field name="status"/>
                <field name="job_id" optional="hide"/>
                <field name="error_message" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         language.translation — form view
    ============================================================ -->
    <record id="view_language_translation_form" model="ir.ui.view">
        <field name="name">language.translation.form</field>
        <field name="model">language.translation</field>
        <field name="arch" type="xml">
            <form string="Translation">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,processing,completed,failed"/>
                    <button name="action_retry" type="object" string="Retry"
                            invisible="status not in ('failed', 'pending')"/>
                </header>
                <sheet>
                    <group>
                        <field name="entry_id"/>
                        <field name="target_language"/>
                        <field name="translated_text"/>
                        <field name="job_id"/>
                        <field name="error_message" invisible="status != 'failed'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         Menu entry under the Lexora backend menu
    ============================================================ -->
    <record id="action_language_translation" model="ir.actions.act_window">
        <field name="name">Translations</field>
        <field name="res_model">language.translation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_entry': 1}</field>
    </record>

</odoo>
