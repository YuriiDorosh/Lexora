<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate=0 so renames and additions apply on every update run -->
    <data noupdate="0">

        <record id="menu_navbar_articles" model="website.menu">
            <field name="name">Community Posts</field>
            <field name="url">/posts</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">20</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">True</field>
        </record>

        <!-- Translator — public, always visible -->
        <record id="menu_translator" model="website.menu">
            <field name="name">Translator</field>
            <field name="url">/translator</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">22</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">True</field>
        </record>

        <!-- AI Roleplay — authenticated only -->
        <record id="menu_ai_roleplay" model="website.menu">
            <field name="name">AI Roleplay</field>
            <field name="url">/my/roleplay</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">26</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

        <!-- Grammar Pro — authenticated only -->
        <record id="menu_grammar_pro" model="website.menu">
            <field name="name">Grammar Pro</field>
            <field name="url">/my/grammar-practice</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">27</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

        <!-- Library dropdown parent -->
        <record id="menu_library_parent" model="website.menu">
            <field name="name">Library</field>
            <field name="url">/useful-words</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">25</field>
        </record>

        <record id="menu_useful_words" model="website.menu">
            <field name="name">Useful Words</field>
            <field name="url">/useful-words</field>
            <field name="parent_id" ref="menu_library_parent"/>
            <field name="sequence">30</field>
        </record>

        <record id="menu_grammar_guide" model="website.menu">
            <field name="name">Grammar Guide</field>
            <field name="url">/grammar</field>
            <field name="parent_id" ref="menu_library_parent"/>
            <field name="sequence">31</field>
        </record>

        <!-- My Posts — portal navbar, authenticated users only -->
        <record id="menu_my_posts" model="website.menu">
            <field name="name">My Posts</field>
            <field name="url">/my/posts</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">62</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

        <!-- Moderation Queue — visible to logged-in users; route guards access internally -->
        <record id="menu_moderation_queue" model="website.menu">
            <field name="name">Moderation Queue</field>
            <field name="url">/my/moderation</field>
            <field name="parent_id" ref="website.main_menu"/>
            <field name="sequence">63</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

    </data>
</odoo>
