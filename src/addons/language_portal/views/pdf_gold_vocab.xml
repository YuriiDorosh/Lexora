<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Gold Vocabulary PDF cheat sheet (by CEFR level)             -->
    <!-- model: language.seeded.word (multi-record)                   -->
    <!-- ============================================================ -->

    <template id="report_gold_vocab_cheat_sheet_document">
        <html>
            <head>
                <meta charset="utf-8"/>
                <link rel="stylesheet"
                      href="/language_portal/static/src/css/print_style.css"/>
            </head>
            <body>
                <!-- Header -->
                <div class="lx-report-header">
                    <span class="lx-logo">Lexora</span>
                    <div>
                        <span class="lx-title">Gold Vocabulary · Level </span>
                        <span t-attf-class="lx-level-badge lx-level-#{active_level.lower()}">
                            <t t-esc="active_level"/>
                        </span>
                    </div>
                    <span class="lx-meta">
                        <t t-esc="word_count"/> words ·
                        <t t-esc="date_generated"/>
                    </span>
                </div>

                <!-- Word grid -->
                <div class="lx-word-grid">
                    <t t-foreach="words" t-as="word">
                        <div class="lx-word-card">
                            <div>
                                <span class="lx-word"><t t-esc="word.word"/></span>
                                <t t-if="word.pos">
                                    <span class="lx-pos"><t t-esc="word.pos"/></span>
                                </t>
                            </div>
                            <t t-if="word.translation_uk">
                                <div class="lx-translation">
                                    <span class="lx-flag">🇺🇦</span>
                                    <t t-esc="word.translation_uk"/>
                                </div>
                            </t>
                            <t t-if="word.translation_el">
                                <div class="lx-translation">
                                    <span class="lx-flag">🇬🇷</span>
                                    <t t-esc="word.translation_el"/>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>

                <!-- Footer -->
                <div style="text-align:center;font-size:7pt;color:#9ca3af;
                            border-top:1px solid #e5e7eb;padding-top:4pt;margin-top:8pt;">
                    Generated by Lexora · 3000 Most Common English Words (CEFR)
                </div>
            </body>
        </html>
    </template>

</odoo>
