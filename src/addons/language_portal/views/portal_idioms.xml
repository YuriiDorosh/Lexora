<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="portal_idioms_index" name="Idioms Hub">
  <t t-call="portal.frontend_layout">
    <t t-set="title">Idioms Hub</t>

    <div id="wrap" class="lx-premium-theme" style="background:#0f172a;min-height:100vh">

      <!-- Hero -->
      <section style="background:linear-gradient(135deg,#0a1628 0%,#1a2744 50%,#0d1f3c 100%);padding:48px 0 32px">
        <div class="container text-center">
          <h1 class="display-5 fw-bold mb-2" style="color:#ffffff">💬 Idioms Hub</h1>
          <p class="lead mb-0" style="color:rgba(255,255,255,0.65)">Master idiomatic expressions with flip cards — expression on front, meaning on back.</p>
        </div>
      </section>

      <div class="container py-4 pb-5">

        <!-- Filters bar -->
        <div class="card mb-4 border-0" style="background:#1e293b;border:1px solid rgba(255,255,255,0.08)!important;border-radius:14px">
          <div class="card-body p-3">
            <form method="GET" action="/idioms" class="row g-2 align-items-end">
              <!-- Language tabs -->
              <div class="col-12 mb-2">
                <div class="d-flex gap-2 flex-wrap">
                  <t t-foreach="[('en','🇬🇧 English'), ('uk','🇺🇦 Ukrainian'), ('el','🇬🇷 Greek'), ('pl','🇵🇱 Polish')]" t-as="lp">
                    <a t-attf-href="/idioms?lang=#{lp[0]}#{active_category and '&amp;category=' + active_category or ''}#{active_level and '&amp;level=' + active_level or ''}"
                       t-attf-style="display:inline-block;padding:6px 14px;border-radius:8px;text-decoration:none;font-size:0.875rem;font-weight:600;#{active_lang == lp[0] and 'background:linear-gradient(90deg,#3b82f6,#1d4ed8);color:#fff;border:none' or 'background:rgba(255,255,255,0.07);color:#94a3b8;border:1px solid rgba(255,255,255,0.15)'}">
                      <t t-esc="lp[1]"/>
                      <span class="badge ms-1" style="background:rgba(255,255,255,0.15);color:#cbd5e1">
                        <t t-esc="lang_counts.get(lp[0], 0)"/>
                      </span>
                    </a>
                  </t>
                </div>
              </div>
              <!-- Category -->
              <div class="col-auto">
                <select name="category" class="form-select form-select-sm"
                        style="background:#1a1a2e;color:#e0e0e0;border:1px solid rgba(255,255,255,0.15);border-radius:8px"
                        onchange="this.form.submit()">
                  <option value="">All Categories</option>
                  <t t-foreach="category_labels.items()" t-as="cat">
                    <option t-att-value="cat[0]" t-att-selected="active_category == cat[0]">
                      <t t-esc="cat[1]"/>
                    </option>
                  </t>
                </select>
              </div>
              <!-- Level -->
              <div class="col-auto">
                <select name="level" class="form-select form-select-sm"
                        style="background:#1a1a2e;color:#e0e0e0;border:1px solid rgba(255,255,255,0.15);border-radius:8px"
                        onchange="this.form.submit()">
                  <option value="">All Levels</option>
                  <t t-foreach="levels" t-as="lv">
                    <option t-att-value="lv" t-att-selected="active_level == lv">
                      <t t-esc="lv"/>
                    </option>
                  </t>
                </select>
              </div>
              <!-- Search -->
              <div class="col">
                <div class="input-group input-group-sm">
                  <input type="text" name="q" class="form-control"
                         style="background:#1a1a2e;color:#e0e0e0;border:1px solid rgba(255,255,255,0.15)"
                         placeholder="Search expression…" t-att-value="search_q"/>
                  <input type="hidden" name="lang" t-att-value="active_lang"/>
                  <button type="submit" class="btn btn-sm" style="background:linear-gradient(90deg,#3b82f6,#1d4ed8);color:#fff;border:none;border-radius:0 8px 8px 0">Search</button>
                </div>
              </div>
            </form>
          </div>
        </div>

        <!-- Cards grid -->
        <t t-if="idioms">
          <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            <t t-foreach="idioms" t-as="idiom">
              <div class="col">
                <!-- Flip card wrapper -->
                <div class="lx-flip-card" onclick="this.classList.toggle('lx-flipped')"
                     tabindex="0"
                     onkeydown="if(event.key==='Enter'||event.key===' ')this.classList.toggle('lx-flipped')">
                  <div class="lx-flip-inner">

                    <!-- FRONT: expression -->
                    <div class="lx-flip-front h-100" style="background:#1e293b;border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:20px;display:flex;flex-direction:column">
                      <div class="d-flex justify-content-between align-items-start mb-3">
                        <span t-attf-class="badge bg-#{level_colors.get(idiom.level, 'secondary')}">
                          <t t-esc="idiom.level"/>
                        </span>
                        <span class="badge" style="background:rgba(255,255,255,0.12);color:#cbd5e1">
                          <t t-esc="category_labels.get(idiom.category, idiom.category)"/>
                        </span>
                      </div>
                      <div class="text-center my-auto">
                        <h4 class="lx-idiom-expression mb-2" style="color:#f1f5f9">
                          <t t-esc="idiom.expression"/>
                        </h4>
                        <t t-if="idiom.literal_meaning">
                          <p class="small mb-0" style="color:rgba(255,255,255,0.5)">
                            Literal: <em><t t-esc="idiom.literal_meaning"/></em>
                          </p>
                        </t>
                      </div>
                      <p class="text-center small mt-3 mb-0" style="color:rgba(255,255,255,0.35)">
                        Click to reveal meaning ↓
                      </p>
                    </div>

                    <!-- BACK: meaning + example -->
                    <div class="lx-flip-back h-100" style="background:#1e3a5f;border:1px solid rgba(59,130,246,0.3);border-radius:16px;padding:20px;display:flex;flex-direction:column">
                      <div class="d-flex justify-content-between align-items-start mb-3">
                        <span t-attf-class="badge bg-#{level_colors.get(idiom.level, 'secondary')}">
                          <t t-esc="idiom.level"/>
                        </span>
                        <span class="badge" style="background:linear-gradient(90deg,#3b82f6,#1d4ed8);color:#fff">Meaning</span>
                      </div>
                      <h5 class="lx-idiom-expression mb-3" style="color:#93c5fd">
                        <t t-esc="idiom.expression"/>
                      </h5>
                      <p class="mb-3" style="color:#e2e8f0">
                        <t t-esc="idiom.idiomatic_meaning"/>
                      </p>
                      <t t-if="idiom.example">
                        <div class="p-2 rounded mb-2" style="background:rgba(255,255,255,0.08);border-left:3px solid #3b82f6">
                          <p class="mb-0 fst-italic small" style="color:#cbd5e1">
                            "<t t-esc="idiom.example"/>"
                          </p>
                        </div>
                      </t>
                      <t t-if="idiom.origin_note">
                        <p class="small mb-0 mt-2" style="color:rgba(255,255,255,0.5)">
                          📌 <t t-esc="idiom.origin_note"/>
                        </p>
                      </t>
                      <p class="text-center small mt-auto mb-0 pt-3" style="color:rgba(255,255,255,0.35)">
                        Click to flip back ↑
                      </p>
                    </div>

                  </div>
                </div>
              </div>
            </t>
          </div>
        </t>

        <t t-else="">
          <div class="text-center py-5">
            <div class="display-1 mb-3">💬</div>
            <h3 style="color:rgba(255,255,255,0.6)">No idioms found</h3>
            <p style="color:rgba(255,255,255,0.4)">Try a different language, category, or search term.</p>
            <a href="/idioms" class="btn btn-sm mt-2" style="background:linear-gradient(90deg,#3b82f6,#1d4ed8);color:#fff;border:none;border-radius:8px">Clear Filters</a>
          </div>
        </t>

      </div>
    </div>
  </t>
</template>

</data>
</odoo>
