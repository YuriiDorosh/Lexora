<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_idioms_index" name="Idioms Hub">
        <t t-call="portal.frontend_layout">
            <t t-set="title">Idioms &amp; Phrasal Verbs</t>
            <div id="wrap" class="oe_structure lx-premium-theme">

                <!-- Hero -->
                <section class="lx-hero-section py-4 mb-4">
                    <div class="container">
                        <h1 class="lx-hero-title mb-1">Idioms &amp; Phrasal Verbs</h1>
                        <p class="lx-hero-sub text-white-50">Natural speech expressions in English and Greek</p>
                    </div>
                </section>

                <div class="container pb-5">
                    <!-- Filters -->
                    <form method="get" action="/idioms" class="row g-2 mb-4">
                        <div class="col-auto">
                            <select name="language" class="form-select form-select-sm lx-filter-select">
                                <option value="">All Languages</option>
                                <t t-foreach="languages" t-as="lopt">
                                    <option t-att-value="lopt[0]"
                                            t-att-selected="filter_language == lopt[0]">
                                        <t t-out="lopt[1]"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="col-auto">
                            <select name="category" class="form-select form-select-sm lx-filter-select">
                                <option value="">All Categories</option>
                                <t t-foreach="categories" t-as="copt">
                                    <option t-att-value="copt[0]"
                                            t-att-selected="filter_category == copt[0]">
                                        <t t-out="copt[1]"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="col-auto">
                            <select name="level" class="form-select form-select-sm lx-filter-select">
                                <option value="">All Levels</option>
                                <t t-foreach="levels" t-as="lvopt">
                                    <option t-att-value="lvopt[0]"
                                            t-att-selected="filter_level == lvopt[0]">
                                        <t t-out="lvopt[1]"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-sm lx-btn-primary">Filter</button>
                            <a href="/idioms" class="btn btn-sm btn-outline-secondary ms-1">Reset</a>
                        </div>
                    </form>

                    <!-- Count -->
                    <p class="text-white-50 small mb-3">
                        <t t-out="len(idioms)"/> expression(s) found
                    </p>

                    <!-- Cards grid -->
                    <t t-if="not idioms">
                        <div class="lx-glass-card p-5 text-center text-white-50">
                            <p class="mb-0">No idioms match your filters. <a href="/idioms" class="lx-link">Reset filters</a></p>
                        </div>
                    </t>
                    <div t-else="" class="row g-3">
                        <t t-foreach="idioms" t-as="idiom">
                            <div class="col-md-6 col-lg-4">
                                <a t-attf-href="/idioms/{{ idiom.id }}" class="text-decoration-none">
                                    <div class="lx-glass-card p-3 h-100 lx-idiom-card">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <span class="lx-badge lx-badge-level">
                                                <t t-out="idiom.level"/>
                                            </span>
                                            <span class="lx-badge lx-badge-lang text-uppercase">
                                                <t t-out="idiom.language"/>
                                            </span>
                                        </div>
                                        <h5 class="text-white fw-bold mb-1">
                                            <t t-out="idiom.expression"/>
                                        </h5>
                                        <p class="text-white-50 small mb-2">
                                            <t t-out="idiom.idiomatic_meaning"/>
                                        </p>
                                        <p class="text-white-50 small fst-italic mb-0" t-if="idiom.example">
                                            "<t t-out="idiom.example"/>"
                                        </p>
                                    </div>
                                </a>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_idioms_detail" name="Idiom Detail">
        <t t-call="portal.frontend_layout">
            <t t-set="title" t-value="idiom.expression"/>
            <div id="wrap" class="oe_structure lx-premium-theme">
                <div class="container py-5">
                    <a href="/idioms" class="btn btn-sm btn-outline-secondary mb-4">← Back to Idioms</a>

                    <div class="lx-glass-card p-4 p-md-5">
                        <div class="d-flex gap-2 mb-3">
                            <span class="lx-badge lx-badge-level"><t t-out="idiom.level"/></span>
                            <span class="lx-badge lx-badge-lang text-uppercase"><t t-out="idiom.language"/></span>
                        </div>

                        <h1 class="text-white fw-bold mb-1">
                            <t t-out="idiom.expression"/>
                        </h1>

                        <t t-if="idiom.literal_meaning">
                            <p class="text-white-50 mb-3">
                                <strong class="text-white-50">Literal:</strong>
                                <t t-out="idiom.literal_meaning"/>
                            </p>
                        </t>

                        <hr class="border-secondary"/>

                        <h5 class="text-white mt-3 mb-1">Meaning</h5>
                        <p class="text-white"><t t-out="idiom.idiomatic_meaning"/></p>

                        <t t-if="idiom.example">
                            <h5 class="text-white mt-3 mb-1">Example</h5>
                            <p class="text-white fst-italic">"<t t-out="idiom.example"/>"</p>
                        </t>

                        <t t-if="idiom.origin_note">
                            <h5 class="text-white mt-3 mb-1">Origin</h5>
                            <p class="text-white-50"><t t-out="idiom.origin_note"/></p>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
