<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Vocabulary list: inject Print Cheat Sheet button             -->
    <!-- ============================================================ -->

    <template id="portal_vocabulary_print_button"
              inherit_id="language_words.portal_vocabulary_list"
              name="Vocabulary Print Button">
        <!-- Inject Print button into the action button group in the page header -->
        <xpath expr="//div[hasclass('d-flex','gap-2')][a[contains(@href,'/my/vocabulary/new')]]"
               position="inside">
            <a href="/my/vocabulary/print"
               class="btn btn-outline-secondary btn-sm btn-print">
                🖨️ Print Cheat Sheet
            </a>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Personal Vocabulary PDF cheat sheet document                 -->
    <!-- ============================================================ -->

    <!-- Main layout used directly by the print controller -->
    <template id="report_vocabulary_cheat_sheet_document">
        <html>
            <head>
                <meta charset="utf-8"/>
                <style t-attf-src="/web/static/src/libs/bootstrap/css/bootstrap.min.css"/>
                <link rel="stylesheet"
                      href="/language_portal/static/src/css/print_style.css"/>
                <style>
                    body { margin: 0; padding: 0; }
                </style>
            </head>
            <body>
                <!-- Header -->
                <div class="lx-report-header">
                    <span class="lx-logo">Lexora</span>
                    <span class="lx-title">My Vocabulary Cheat Sheet</span>
                    <span class="lx-meta">
                        <t t-esc="entry_count"/> words ·
                        <t t-esc="date_generated"/>
                    </span>
                </div>

                <!-- Group by source language -->
                <t t-foreach="lang_groups" t-as="lg">
                    <div class="lx-section-title">
                        <t t-esc="lg['label']"/>
                        (<t t-esc="len(lg['entries'])"/> words)
                    </div>

                    <div class="lx-word-grid">
                        <t t-foreach="lg['entries']" t-as="entry">
                            <div class="lx-word-card">
                                <div>
                                    <span class="lx-word"><t t-esc="entry.source_text"/></span>
                                    <span class="lx-pos"><t t-esc="entry.type"/></span>
                                </div>
                                <!-- Translations -->
                                <t t-foreach="entry.translation_ids" t-as="tr">
                                    <t t-if="tr.status == 'completed' and tr.translated_text">
                                        <div class="lx-translation">
                                            <span class="lx-flag">
                                                <t t-if="tr.target_language == 'uk'">🇺🇦</t>
                                                <t t-elif="tr.target_language == 'el'">🇬🇷</t>
                                                <t t-else="">🌐</t>
                                            </span>
                                            <t t-esc="tr.translated_text"/>
                                        </div>
                                    </t>
                                </t>
                                <!-- First completed enrichment example sentence -->
                                <t t-foreach="entry.enrichment_ids" t-as="en">
                                    <t t-if="en.status == 'completed'">
                                        <t t-set="sentences" t-value="en._example_sentences_list()"/>
                                        <t t-if="sentences">
                                            <div class="lx-example">
                                                <t t-esc="sentences[0]"/>
                                            </div>
                                        </t>
                                    </t>
                                </t>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- Footer -->
                <div style="text-align:center;font-size:7pt;color:#9ca3af;
                            border-top:1px solid #e5e7eb;padding-top:4pt;margin-top:8pt;">
                    Generated by Lexora · lexora.app
                </div>
            </body>
        </html>
    </template>

</odoo>
