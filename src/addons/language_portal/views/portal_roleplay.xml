<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Roleplay Scenario Grid  /my/roleplay
    ================================================================ -->
    <template id="portal_roleplay_grid" name="AI Roleplay — Scenario Grid">
        <t t-call="portal.frontend_layout">
            <t t-set="title">AI Roleplay</t>
            <div id="wrap" class="lx-premium-theme" style="background:#0f172a;min-height:100vh">

                <!-- Hero -->
                <section style="background:linear-gradient(135deg,#1a0533 0%,#2d0b5e 50%,#0d1b4b 100%);padding:56px 0 40px">
                    <div class="container text-center">
                        <h1 class="display-5 fw-bold mb-2" style="color:#ffffff">🎭 AI Roleplay</h1>
                        <p class="lead mb-0" style="color:rgba(255,255,255,0.65)">Practice real conversations with an AI language partner. Get instant corrections and build confidence.</p>
                    </div>
                </section>

                <!-- Scenario cards -->
                <div style="background:#0f172a;padding:40px 0 60px">
                    <div class="container">
                        <div class="row g-4">
                            <t t-foreach="scenarios" t-as="sc">
                                <div class="col-md-6 col-lg-4">
                                    <div style="background:#1e293b;border:1px solid rgba(255,255,255,0.08);border-radius:16px;height:100%;transition:transform 0.2s,box-shadow 0.2s;display:flex;flex-direction:column"
                                         onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 32px rgba(138,43,226,0.3)'"
                                         onmouseout="this.style.transform='';this.style.boxShadow=''">
                                        <div style="padding:24px;display:flex;flex-direction:column;flex:1">
                                            <div class="d-flex align-items-center mb-3">
                                                <span style="font-size:2.5rem;margin-right:14px;line-height:1"><t t-esc="sc.icon"/></span>
                                                <div>
                                                    <h5 class="mb-1 fw-bold" style="font-size:1rem;color:#f1f5f9"><t t-esc="sc.name"/></h5>
                                                    <span class="badge" style="background:linear-gradient(90deg,#8a2be2,#4169e1);font-size:0.7rem">
                                                        <t t-esc="sc.difficulty"/>
                                                    </span>
                                                    <span class="badge ms-1" style="background:rgba(255,255,255,0.1);color:#94a3b8;font-size:0.7rem">
                                                        <t t-if="sc.target_language == 'en'">🇬🇧 English</t>
                                                        <t t-elif="sc.target_language == 'uk'">🇺🇦 Ukrainian</t>
                                                        <t t-elif="sc.target_language == 'el'">🇬🇷 Greek</t>
                                                    </span>
                                                </div>
                                            </div>
                                            <p style="color:#94a3b8;font-size:0.875rem;line-height:1.6;flex:1;margin-bottom:20px"><t t-esc="sc.description"/></p>
                                            <a t-attf-href="/my/roleplay/#{sc.id}"
                                               style="display:block;background:linear-gradient(90deg,#8a2be2,#4169e1);color:#fff;border:none;border-radius:8px;font-weight:600;text-align:center;padding:10px;text-decoration:none;font-size:0.9rem">
                                                Start Conversation →
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>

                        <t t-if="not scenarios">
                            <div class="text-center py-5">
                                <p style="color:rgba(255,255,255,0.5)">No roleplay scenarios available yet.</p>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Roleplay Chat  /my/roleplay/<id>
    ================================================================ -->
    <template id="portal_roleplay_chat" name="AI Roleplay — Chat">
        <t t-call="portal.frontend_layout">
            <t t-set="title" t-value="scenario.name"/>
            <div id="wrap" class="lx-premium-theme" style="background:#0f172a;min-height:100vh">

                <div class="container py-4" style="max-width:860px">

                    <!-- Back + header -->
                    <div class="d-flex align-items-center mb-4 gap-3">
                        <a href="/my/roleplay" class="btn btn-sm" style="background:rgba(255,255,255,0.08);color:#cbd5e1;border:1px solid rgba(255,255,255,0.15);border-radius:8px">
                            ← Back
                        </a>
                        <div>
                            <h2 class="mb-0 fw-bold" style="font-size:1.3rem;color:#f1f5f9">
                                <t t-esc="scenario.icon"/> <t t-esc="scenario.name"/>
                            </h2>
                            <span class="badge" style="background:linear-gradient(90deg,#8a2be2,#4169e1);font-size:0.7rem">
                                <t t-esc="scenario.difficulty"/>
                            </span>
                            <span style="color:#64748b;font-size:0.8rem;margin-left:8px">
                                <t t-if="scenario.target_language == 'en'">🇬🇧 English</t>
                                <t t-elif="scenario.target_language == 'uk'">🇺🇦 Ukrainian</t>
                                <t t-elif="scenario.target_language == 'el'">🇬🇷 Greek</t>
                            </span>
                        </div>
                        <div class="ms-auto">
                            <form t-attf-action="/my/roleplay/#{scenario.id}/reset" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-sm" style="background:rgba(220,53,69,0.15);color:#f87171;border:1px solid rgba(239,68,68,0.3);border-radius:8px"
                                        onclick="return confirm('Reset this conversation?')">
                                    🔄 Reset
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Chat box -->
                    <div id="lx-chat-box"
                         style="background:#1e293b;border:1px solid rgba(255,255,255,0.08);border-radius:16px;min-height:420px;max-height:520px;overflow-y:auto;padding:24px;display:flex;flex-direction:column;gap:12px">

                        <t t-if="not history">
                            <div class="text-center py-4">
                                <p style="font-size:1.1rem;color:rgba(255,255,255,0.6)">👋 Start the conversation below!</p>
                                <p style="font-size:0.875rem;color:rgba(255,255,255,0.4)">The AI will respond in character and correct your mistakes.</p>
                            </div>
                        </t>

                        <t t-foreach="history" t-as="msg">
                            <t t-if="msg['role'] == 'user'">
                                <div class="d-flex justify-content-end">
                                    <div style="max-width:75%;background:linear-gradient(135deg,#8a2be2,#4169e1);color:#ffffff;border-radius:16px 16px 4px 16px;padding:12px 16px;font-size:0.92rem;line-height:1.5">
                                        <t t-esc="msg['content']"/>
                                    </div>
                                </div>
                            </t>
                            <t t-if="msg['role'] == 'assistant'">
                                <div class="d-flex justify-content-start">
                                    <div style="max-width:80%;background:#334155;border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:16px 16px 16px 4px;padding:12px 16px;font-size:0.92rem;line-height:1.6">
                                        <t t-esc="msg['content']"/>
                                    </div>
                                </div>
                            </t>
                        </t>

                        <!-- Typing indicator -->
                        <div id="lx-typing" class="d-none d-flex justify-content-start">
                            <div style="background:#334155;border:1px solid rgba(255,255,255,0.1);color:#94a3b8;border-radius:16px;padding:10px 16px;font-size:0.85rem">
                                ✦ Typing…
                            </div>
                        </div>
                    </div>

                    <!-- Input row -->
                    <div class="mt-3 d-flex gap-2">
                        <input id="lx-msg-input" type="text" class="form-control"
                               placeholder="Type your message… (Enter to send)"
                               style="background:#1e293b;border:1px solid rgba(255,255,255,0.18);color:#f1f5f9;border-radius:10px;font-size:0.93rem"
                               autocomplete="off"/>
                        <button id="lx-send-btn" class="btn px-4"
                                style="background:linear-gradient(90deg,#8a2be2,#4169e1);color:#fff;border:none;border-radius:10px;font-weight:600;white-space:nowrap">
                            Send →
                        </button>
                    </div>
                    <p style="font-size:0.8rem;margin-top:8px;color:rgba(255,255,255,0.35)">Press <kbd style="background:#334155;color:#94a3b8;border:1px solid rgba(255,255,255,0.15);border-radius:4px;padding:1px 5px">Enter</kbd> to send · The AI responds in character and corrects grammar mistakes.</p>

                </div>
            </div>

            <script type="text/javascript">
            (function() {
                var scenarioId = <t t-esc="scenario.id"/>;
                var chatBox = document.getElementById('lx-chat-box');
                var input = document.getElementById('lx-msg-input');
                var sendBtn = document.getElementById('lx-send-btn');
                var typing = document.getElementById('lx-typing');

                function scrollToBottom() {
                    chatBox.scrollTop = chatBox.scrollHeight;
                }
                scrollToBottom();

                function appendBubble(role, content) {
                    var isUser = role === 'user';
                    var wrap = document.createElement('div');
                    wrap.className = 'd-flex ' + (isUser ? 'justify-content-end' : 'justify-content-start');
                    var bubble = document.createElement('div');
                    bubble.textContent = content;
                    if (isUser) {
                        bubble.style.cssText = 'max-width:75%;background:linear-gradient(135deg,#8a2be2,#4169e1);color:#ffffff;border-radius:16px 16px 4px 16px;padding:12px 16px;font-size:0.92rem;line-height:1.5';
                    } else {
                        bubble.style.cssText = 'max-width:80%;background:#334155;border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:16px 16px 16px 4px;padding:12px 16px;font-size:0.92rem;line-height:1.6';
                    }
                    wrap.appendChild(bubble);
                    chatBox.insertBefore(wrap, typing);
                    scrollToBottom();
                }

                function sendMessage() {
                    var msg = input.value.trim();
                    if (!msg) return;
                    input.value = '';
                    input.disabled = true;
                    sendBtn.disabled = true;
                    appendBubble('user', msg);
                    typing.classList.remove('d-none');
                    scrollToBottom();

                    fetch('/my/roleplay/' + scenarioId + '/send', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({jsonrpc:'2.0',method:'call',params:{message: msg}})
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        typing.classList.add('d-none');
                        var reply = (data.result &amp;&amp; data.result.reply) || '…';
                        appendBubble('assistant', reply);
                    })
                    .catch(function() {
                        typing.classList.add('d-none');
                        appendBubble('assistant', 'Sorry, something went wrong. Please try again!');
                    })
                    .finally(function() {
                        input.disabled = false;
                        sendBtn.disabled = false;
                        input.focus();
                    });
                }

                sendBtn.addEventListener('click', sendMessage);
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') { e.preventDefault(); sendMessage(); }
                });
            })();
            </script>

        </t>
    </template>

</odoo>
