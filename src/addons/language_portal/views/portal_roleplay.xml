<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Roleplay Scenario Grid  /my/roleplay
    ================================================================ -->
    <template id="portal_roleplay_grid" name="AI Roleplay — Scenario Grid">
        <t t-call="portal.frontend_layout">
            <t t-set="title">AI Roleplay</t>
            <div id="wrap" class="oe_structure lx-premium-theme">

                <!-- Hero -->
                <section class="lx-hero py-5" style="background:linear-gradient(135deg,#1a0533 0%,#2d0b5e 50%,#0d1b4b 100%);min-height:200px">
                    <div class="container text-center py-3">
                        <h1 class="display-5 fw-bold text-white mb-2">🎭 AI Roleplay</h1>
                        <p class="lead text-white-50">Practice real conversations with an AI language partner. Get instant corrections and build confidence.</p>
                    </div>
                </section>

                <div class="container py-5">
                    <div class="row g-4">
                        <t t-foreach="scenarios" t-as="sc">
                            <div class="col-md-6 col-lg-4">
                                <div class="card h-100 border-0 shadow-sm" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08)!important;border-radius:16px;transition:transform 0.2s,box-shadow 0.2s;"
                                     onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 32px rgba(138,43,226,0.25)'"
                                     onmouseout="this.style.transform='';this.style.boxShadow=''">
                                    <div class="card-body p-4">
                                        <div class="d-flex align-items-center mb-3">
                                            <span style="font-size:2.5rem;margin-right:14px"><t t-esc="sc.icon"/></span>
                                            <div>
                                                <h5 class="mb-1 text-white fw-bold" style="font-size:1rem"><t t-esc="sc.name"/></h5>
                                                <span class="badge" style="background:linear-gradient(90deg,#8a2be2,#4169e1);font-size:0.7rem">
                                                    <t t-esc="sc.difficulty"/>
                                                </span>
                                                <span class="badge ms-1" style="background:rgba(255,255,255,0.1);color:#aaa;font-size:0.7rem">
                                                    <t t-if="sc.target_language == 'en'">🇬🇧 English</t>
                                                    <t t-elif="sc.target_language == 'uk'">🇺🇦 Ukrainian</t>
                                                    <t t-elif="sc.target_language == 'el'">🇬🇷 Greek</t>
                                                </span>
                                            </div>
                                        </div>
                                        <p class="text-white-50 small mb-4" style="line-height:1.5"><t t-esc="sc.description"/></p>
                                        <a t-attf-href="/my/roleplay/#{sc.id}"
                                           class="btn btn-sm w-100"
                                           style="background:linear-gradient(90deg,#8a2be2,#4169e1);color:#fff;border:none;border-radius:8px;font-weight:600">
                                            Start Conversation →
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>

                    <t t-if="not scenarios">
                        <div class="text-center py-5">
                            <p class="text-muted">No roleplay scenarios available yet.</p>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- ================================================================
         Roleplay Chat  /my/roleplay/<id>
    ================================================================ -->
    <template id="portal_roleplay_chat" name="AI Roleplay — Chat">
        <t t-call="portal.frontend_layout">
            <t t-set="title" t-value="scenario.name"/>
            <div id="wrap" class="lx-premium-theme">

                <div class="container py-4" style="max-width:860px">

                    <!-- Back + header -->
                    <div class="d-flex align-items-center mb-4 gap-3">
                        <a href="/my/roleplay" class="btn btn-sm" style="background:rgba(255,255,255,0.08);color:#ccc;border:1px solid rgba(255,255,255,0.15);border-radius:8px">
                            ← Back
                        </a>
                        <div>
                            <h2 class="mb-0 text-white fw-bold" style="font-size:1.3rem">
                                <t t-esc="scenario.icon"/> <t t-esc="scenario.name"/>
                            </h2>
                            <span class="badge" style="background:linear-gradient(90deg,#8a2be2,#4169e1);font-size:0.7rem">
                                <t t-esc="scenario.difficulty"/>
                            </span>
                            <span class="text-white-50 small ms-2">
                                <t t-if="scenario.target_language == 'en'">🇬🇧 English</t>
                                <t t-elif="scenario.target_language == 'uk'">🇺🇦 Ukrainian</t>
                                <t t-elif="scenario.target_language == 'el'">🇬🇷 Greek</t>
                            </span>
                        </div>
                        <div class="ms-auto">
                            <form t-attf-action="/my/roleplay/#{scenario.id}/reset" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-sm" style="background:rgba(220,53,69,0.15);color:#f66;border:1px solid rgba(220,53,69,0.3);border-radius:8px"
                                        onclick="return confirm('Reset this conversation?')">
                                    🔄 Reset
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Chat box -->
                    <div id="lx-chat-box"
                         style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:16px;min-height:420px;max-height:520px;overflow-y:auto;padding:24px;display:flex;flex-direction:column;gap:12px">

                        <t t-if="not history">
                            <div class="text-center text-white-50 py-4">
                                <p style="font-size:1.1rem">👋 Start the conversation below!</p>
                                <p class="small">The AI will respond in character and correct your mistakes.</p>
                            </div>
                        </t>

                        <t t-foreach="history" t-as="msg">
                            <!-- User bubble -->
                            <t t-if="msg['role'] == 'user'">
                                <div class="d-flex justify-content-end">
                                    <div style="max-width:75%;background:linear-gradient(135deg,#8a2be2,#4169e1);color:#fff;border-radius:16px 16px 4px 16px;padding:12px 16px;font-size:0.92rem;line-height:1.5">
                                        <t t-esc="msg['content']"/>
                                    </div>
                                </div>
                            </t>
                            <!-- AI bubble -->
                            <t t-if="msg['role'] == 'assistant'">
                                <div class="d-flex justify-content-start">
                                    <div style="max-width:80%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:#e0e0e0;border-radius:16px 16px 16px 4px;padding:12px 16px;font-size:0.92rem;line-height:1.6">
                                        <t t-esc="msg['content']"/>
                                    </div>
                                </div>
                            </t>
                        </t>

                        <!-- Typing indicator (hidden by default) -->
                        <div id="lx-typing" class="d-none d-flex justify-content-start">
                            <div style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:#aaa;border-radius:16px;padding:10px 16px;font-size:0.85rem">
                                ✦ Typing…
                            </div>
                        </div>
                    </div>

                    <!-- Input row -->
                    <div class="mt-3 d-flex gap-2" id="lx-chat-form">
                        <input id="lx-msg-input" type="text" class="form-control"
                               placeholder="Type your message… (Enter to send)"
                               style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.18);color:#fff;border-radius:10px;font-size:0.93rem"
                               autocomplete="off"/>
                        <button id="lx-send-btn" class="btn px-4"
                                style="background:linear-gradient(90deg,#8a2be2,#4169e1);color:#fff;border:none;border-radius:10px;font-weight:600;white-space:nowrap">
                            Send →
                        </button>
                    </div>
                    <p class="text-white-50 small mt-2">Press <kbd>Enter</kbd> to send · The AI responds in character and corrects grammar mistakes.</p>

                </div>
            </div>

            <script type="text/javascript">
            (function() {
                var scenarioId = <t t-esc="scenario.id"/>;
                var chatBox = document.getElementById('lx-chat-box');
                var input = document.getElementById('lx-msg-input');
                var sendBtn = document.getElementById('lx-send-btn');
                var typing = document.getElementById('lx-typing');

                function scrollToBottom() {
                    chatBox.scrollTop = chatBox.scrollHeight;
                }
                scrollToBottom();

                function appendBubble(role, content) {
                    var isUser = role === 'user';
                    var wrap = document.createElement('div');
                    wrap.className = 'd-flex ' + (isUser ? 'justify-content-end' : 'justify-content-start');
                    var bubble = document.createElement('div');
                    bubble.textContent = content;
                    if (isUser) {
                        bubble.style.cssText = 'max-width:75%;background:linear-gradient(135deg,#8a2be2,#4169e1);color:#fff;border-radius:16px 16px 4px 16px;padding:12px 16px;font-size:0.92rem;line-height:1.5';
                    } else {
                        bubble.style.cssText = 'max-width:80%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:#e0e0e0;border-radius:16px 16px 16px 4px;padding:12px 16px;font-size:0.92rem;line-height:1.6';
                    }
                    wrap.appendChild(bubble);
                    chatBox.insertBefore(wrap, typing);
                    scrollToBottom();
                }

                function sendMessage() {
                    var msg = input.value.trim();
                    if (!msg) return;
                    input.value = '';
                    input.disabled = true;
                    sendBtn.disabled = true;
                    appendBubble('user', msg);
                    typing.classList.remove('d-none');
                    scrollToBottom();

                    fetch('/my/roleplay/' + scenarioId + '/send', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({jsonrpc:'2.0',method:'call',params:{message: msg}})
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        typing.classList.add('d-none');
                        var reply = (data.result &amp;&amp; data.result.reply) || '…';
                        appendBubble('assistant', reply);
                    })
                    .catch(function() {
                        typing.classList.add('d-none');
                        appendBubble('assistant', 'Sorry, something went wrong. Please try again!');
                    })
                    .finally(function() {
                        input.disabled = false;
                        sendBtn.disabled = false;
                        input.focus();
                    });
                }

                sendBtn.addEventListener('click', sendMessage);
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') { e.preventDefault(); sendMessage(); }
                });

                // Remove empty state on first message
                var emptyState = chatBox.querySelector('.text-center.text-white-50');
                if (emptyState &amp;&amp; emptyState.parentNode.children.length === 1) {
                    input.addEventListener('keydown', function() {
                        if (emptyState &amp;&amp; emptyState.parentNode) emptyState.remove();
                    }, {once: true});
                }
            })();
            </script>

        </t>
    </template>

</odoo>
