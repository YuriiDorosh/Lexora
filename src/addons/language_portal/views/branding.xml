<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Google Fonts — <link> injected into <head> on every page     -->
    <!-- Must use a <link> tag; @import in bundled CSS is ignored.     -->
    <!-- ============================================================ -->

    <template id="lexora_google_fonts"
              inherit_id="web.frontend_layout"
              name="Lexora Google Fonts">
        <xpath expr="//head/meta[last()]" position="after">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>
            <link rel="stylesheet"
                  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;family=Montserrat:wght@700;800;900&amp;display=swap"/>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Remove "Powered by Odoo" — replace with Avantgarde credit    -->
    <!-- web.brand_promotion_message is called from every footer      -->
    <!-- ============================================================ -->

    <template id="lexora_brand_promotion"
              inherit_id="web.brand_promotion_message"
              name="Lexora · Remove Odoo Branding">
        <xpath expr="." position="replace">
            <t name="Brand Promotion Message" t-name="web.brand_promotion_message">
                <span class="lx-avantgarde-credit" style="font-size:.78rem;color:#9ca3af">
                    Developed with <span style="color:#f43f5e">❤</span> by
                    <a href="https://avantgarde.systems" target="_blank" rel="noopener"
                       style="color:#9ca3af;text-decoration:none;font-weight:500">Avantgarde Systems</a>
                </span>
            </t>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Footer copyright bar — "Lexora · Avantgarde" credit row      -->
    <!-- web.frontend_layout owns the o_footer_copyright div          -->
    <!-- ============================================================ -->

    <template id="lexora_footer_copyright"
              inherit_id="web.frontend_layout"
              name="Lexora · Footer Avantgarde Credit">
        <xpath expr="//div[hasclass('o_footer_copyright')]//div[hasclass('col-sm','text-center','text-sm-start')]" position="replace">
            <div class="col-sm text-center text-sm-start lx-footer-copyright-text">
                <span>© 2026 Lexora · Built by</span>
                <a href="https://avantgarde.systems" target="_blank" rel="noopener"
                   class="lx-footer-credit-link">Avantgarde Systems</a>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Login page — Lexora gradient title                           -->
    <!-- Targets website.login_layout (website module replaces        -->
    <!-- web.login_layout entirely, stripping the card structure)     -->
    <!-- ============================================================ -->

    <template id="login_avantgarde_brand"
              inherit_id="website.login_layout"
              name="Lexora · Login Branding">
        <xpath expr="//div[hasclass('oe_website_login_container')]" position="before">
            <div class="text-center py-4">
                <div class="lx-login-brand-title">Lexora</div>
                <div class="lx-login-brand-sub">powered by Avantgarde Systems</div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Navbar logo — replace placeholder <img> with Lexora SVG      -->
    <!-- website.option_header_brand_logo is the active logo template -->
    <!-- ============================================================ -->

    <template id="lexora_navbar_logo"
              inherit_id="website.option_header_brand_logo"
              name="Lexora · Navbar Logo">
        <xpath expr="//a[@data-name='Navbar Logo']" position="replace">
            <a data-name="Navbar Logo" href="/" t-attf-class="navbar-brand logo lx-navbar-brand #{_link_class}">
                <span class="lx-nav-logo">Lexora</span>
            </a>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Header cleanup — disable phone number and CTA button         -->
    <!-- Set active=False via noupdate=1 so website module cannot      -->
    <!-- re-enable them on a subsequent website module update pass    -->
    <!-- ============================================================ -->

    <data>
        <!-- Disable the header phone/text block (lorem ipsum phone number) -->
        <record id="website.header_text_element" model="ir.ui.view">
            <field name="active" eval="False"/>
        </record>
        <!-- Disable the "Contact Us" CTA button in header -->
        <record id="website.header_call_to_action" model="ir.ui.view">
            <field name="active" eval="False"/>
        </record>
    </data>

    <!-- ============================================================ -->
    <!-- Footer overhaul — replace lorem ipsum with Avantgarde brand  -->
    <!-- priority=20 beats website.footer_custom (default ~16) so     -->
    <!-- our xpath runs AFTER footer_custom and replaces its content  -->
    <!-- No oe_structure_solo → static output, not editable via CMS   -->
    <!-- ============================================================ -->

    <template id="lexora_footer_content"
              inherit_id="website.layout"
              name="Lexora · Footer Content"
              priority="20">
        <xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" t-if="not no_footer" class="lx-footer">
                <div class="container py-5">
                    <div class="row g-5">

                        <!-- Column 1: Brand + tagline -->
                        <div class="col-lg-4 col-md-6">
                            <div class="lx-footer-brand mb-3">
                                <span class="lx-nav-logo" style="font-size:1.75rem">Lexora</span>
                            </div>
                            <p class="lx-footer-tagline mb-4">
                                AI-powered language learning platform.
                                Master Ukrainian, English &amp; Greek through
                                smart vocabulary, spaced repetition, and live duels.
                            </p>
                            <p class="lx-footer-built-by mb-0">
                                Built with <span class="lx-heart">❤</span> by
                                <a href="https://avantgarde.systems" target="_blank" rel="noopener"
                                   class="lx-footer-credit-link">Avantgarde Systems</a>
                            </p>
                            <p class="lx-footer-built-desc mt-1">
                                Premier software engineering &amp; development firm
                                building advanced, tailored platforms for global enterprises.
                            </p>
                        </div>

                        <!-- Column 2: Quick Links -->
                        <div class="col-lg-2 col-md-3 col-6">
                            <h6 class="lx-footer-heading">Platform</h6>
                            <ul class="list-unstyled lx-footer-links">
                                <li><a href="/">Home</a></li>
                                <li><a href="/posts">Articles</a></li>
                                <li><a href="/useful-words">Useful Words</a></li>
                                <li><a href="/grammar">Grammar Guide</a></li>
                                <li><a href="/my/vocabulary">My Vocabulary</a></li>
                                <li><a href="/my/practice">Daily Practice</a></li>
                                <li><a href="/my/arena">Arena</a></li>
                            </ul>
                        </div>

                        <!-- Column 3: Account links -->
                        <div class="col-lg-2 col-md-3 col-6">
                            <h6 class="lx-footer-heading">Account</h6>
                            <ul class="list-unstyled lx-footer-links">
                                <li><a href="/web/login">Sign In</a></li>
                                <li><a href="/web/signup">Register</a></li>
                                <li><a href="/my/dashboard">My Profile</a></li>
                                <li><a href="/my/leaderboard">Leaderboard</a></li>
                                <li><a href="/my/shop">XP Shop</a></li>
                                <li><a href="/my/chat">Chat</a></li>
                            </ul>
                        </div>

                        <!-- Column 4: Avantgarde contact -->
                        <div class="col-lg-4 col-md-6">
                            <h6 class="lx-footer-heading">Avantgarde Systems</h6>
                            <p class="lx-footer-tagline mb-4">
                                We are a premier software engineering and development firm,
                                dedicated to building advanced, tailored platforms that drive
                                business growth. Our expertise lies in scalable, forward-thinking
                                solutions for global enterprises.
                            </p>
                            <div class="lx-footer-social">
                                <a href="https://avantgarde.systems" target="_blank" rel="noopener"
                                   class="lx-social-link" aria-label="Avantgarde Systems Website">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                                    <span>avantgarde.systems</span>
                                </a>
                                <a href="https://www.linkedin.com/company/112026057/" target="_blank" rel="noopener"
                                   class="lx-social-link" aria-label="Avantgarde Systems on LinkedIn">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                                    <span>LinkedIn</span>
                                </a>
                                <a href="https://github.com/Avantgarde-Systems" target="_blank" rel="noopener"
                                   class="lx-social-link" aria-label="Avantgarde Systems on GitHub">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                                    <span>GitHub</span>
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </xpath>
    </template>


    <!-- ============================================================ -->
    <!-- Portal sidebar — replace Mitchell Admin "Your contact" block -->
    <!-- portal.portal_contact is called from portal.side_content     -->
    <!-- and renders sales_user name/email/phone/city (demo data)     -->
    <!-- Replace with a clean "Verified Lexora Member" badge          -->
    <!-- ============================================================ -->

    <template id="lexora_portal_contact"
              inherit_id="portal.portal_contact"
              name="Lexora · Portal Contact Cleanup">
        <xpath expr="." position="replace">
            <t t-name="portal.portal_contact">
                <div class="lx-member-badge mb-4">
                    <span>✦</span>
                    <span>Verified Lexora Member</span>
                </div>
            </t>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- Portal sidebar — remove address/phone/email block            -->
    <!-- portal.side_content renders partner contact widget with      -->
    <!-- Scranton address, demo email, demo phone                     -->
    <!-- Replace with Lexora Academy branding block                   -->
    <!-- ============================================================ -->

    <template id="lexora_portal_side_content"
              inherit_id="portal.side_content"
              name="Lexora · Portal Sidebar Branding">
        <xpath expr="//div[hasclass('o_portal_my_details')]" position="replace">
            <div class="lx-sidebar-brand mb-3">
                <div class="lx-sb-title">Lexora Academy</div>
                <div class="lx-sb-sub">Powered by
                    <a href="https://avantgarde.systems" target="_blank" rel="noopener"
                       class="lx-sb-credit">Avantgarde Systems</a>
                </div>
            </div>
        </xpath>
        <xpath expr="//a[contains(@href,'/my/account')]" position="replace"/>
    </template>

    <!-- ============================================================ -->
    <!-- Contact page — strip demo company info, show Avantgarde     -->
    <!-- Inherits website.contactus; replaces the right sidebar col  -->
    <!-- that contains "My Company / Fake Buena Vista / 555-555"     -->
    <!-- ============================================================ -->

    <template id="lexora_contactus_cleanup"
              inherit_id="website.contactus"
              name="Lexora · Contact Page Cleanup">
        <xpath expr="//div[hasclass('col-lg-4','offset-lg-1')]" position="replace">
            <div class="col-lg-4 offset-lg-1 mt-4 mt-lg-0">
                <h5 class="fw-bold mb-3">Avantgarde Systems</h5>
                <p class="text-muted small mb-3">
                    Premier software engineering &amp; development firm
                    building advanced, tailored platforms for global enterprises.
                </p>
                <ul class="list-unstyled mb-3 ps-2">
                    <li class="mb-2">
                        <i class="fa fa-globe fa-fw me-2 text-muted"/>
                        <a href="https://avantgarde.systems" target="_blank" rel="noopener"
                           class="text-decoration-none">avantgarde.systems</a>
                    </li>
                    <li class="mb-2">
                        <i class="fa fa-linkedin fa-fw me-2 text-muted"/>
                        <a href="https://www.linkedin.com/company/112026057/" target="_blank" rel="noopener"
                           class="text-decoration-none">LinkedIn</a>
                    </li>
                    <li class="mb-2">
                        <i class="fa fa-github fa-fw me-2 text-muted"/>
                        <a href="https://github.com/Avantgarde-Systems" target="_blank" rel="noopener"
                           class="text-decoration-none">GitHub</a>
                    </li>
                </ul>
                <p class="text-muted small mb-0">
                    <em>Lexora is built with ❤ by Avantgarde Systems.</em>
                </p>
            </div>
        </xpath>
    </template>

</odoo>
