<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Grammar Section PDF cheat sheet                              -->
    <!-- model: language.grammar.section (single record)             -->
    <!-- ============================================================ -->

    <template id="report_grammar_cheat_sheet_document">
        <html>
            <head>
                <meta charset="utf-8"/>
                <link rel="stylesheet"
                      href="/language_portal/static/src/css/print_style.css"/>
            </head>
            <body>
                <!-- Header -->
                <div class="lx-report-header">
                    <span class="lx-logo">Lexora</span>
                    <span class="lx-title">
                        Grammar · <t t-esc="section.title"/>
                    </span>
                    <span class="lx-meta">
                        <t t-esc="date_generated"/>
                    </span>
                </div>

                <!-- Grammar HTML content -->
                <div class="grammar-content">
                    <t t-raw="section.content_html"/>
                </div>

                <!-- Footer -->
                <div style="text-align:center;font-size:7pt;color:#9ca3af;
                            border-top:1px solid #e5e7eb;padding-top:4pt;margin-top:8pt;">
                    Generated by Lexora · Grammar Encyclopedia
                </div>
            </body>
        </html>
    </template>

</odoo>
