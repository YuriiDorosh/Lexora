<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================
             Module category
        ============================================================ -->
        <record id="module_category_language" model="ir.module.category">
            <field name="name">Lexora</field>
            <field name="description">Language learning platform modules</field>
            <field name="sequence">100</field>
        </record>

        <!-- ============================================================
             Security groups (least-privilege order: user < moderator < admin)
        ============================================================ -->

        <!-- Language User: default for all portal signups -->
        <record id="group_language_user" model="res.groups">
            <field name="name">Language User</field>
            <field name="category_id" ref="module_category_language"/>
            <field name="comment">Standard language-learning user. Assigned automatically on portal signup.</field>
        </record>

        <!-- Language Moderator: implies Language User -->
        <record id="group_language_moderator" model="res.groups">
            <field name="name">Language Moderator</field>
            <field name="category_id" ref="module_category_language"/>
            <field name="implied_ids" eval="[(4, ref('language_security.group_language_user'))]"/>
            <field name="comment">Can approve/reject posts, delete messages, mute/ban users.</field>
        </record>

        <!-- Language Admin: implies Language Moderator (and transitively Language User) -->
        <record id="group_language_admin" model="res.groups">
            <field name="name">Language Administrator</field>
            <field name="category_id" ref="module_category_language"/>
            <field name="implied_ids" eval="[(4, ref('language_security.group_language_moderator'))]"/>
            <field name="comment">Full backend access, system settings, job queues, analytics.</field>
        </record>

        <!-- ============================================================
             Auto-assignment: portal signup → Language User
             Any user in base.group_portal is implied to have group_language_user.
        ============================================================ -->
        <record id="base.group_portal" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('language_security.group_language_user'))]"/>
        </record>

    </data>
</odoo>
