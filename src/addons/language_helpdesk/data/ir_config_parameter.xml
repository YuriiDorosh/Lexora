<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- URL of the ai_mentor FastAPI service. Override in .env or system parameters. -->
    <record id="ai_mentor_url" model="ir.config_parameter">
        <field name="key">language.ai_mentor.url</field>
        <field name="value">http://ai-mentor-service:8000</field>
    </record>

    <!-- Timeout (seconds) for the synchronous call to ai_mentor /answer. -->
    <record id="ai_mentor_timeout" model="ir.config_parameter">
        <field name="key">language.ai_mentor.timeout</field>
        <field name="value">35</field>
    </record>

    <!-- Set to "0" to disable auto-reply (manual fallback). -->
    <record id="ai_mentor_enabled" model="ir.config_parameter">
        <field name="key">language.ai_mentor.enabled</field>
        <field name="value">1</field>
    </record>
</odoo>
