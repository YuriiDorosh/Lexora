<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate=0 so parent_id re-parenting applies on every update run -->
    <data noupdate="0">

        <!-- Daily Practice — child of Practice group (language_portal) -->
        <record id="menu_navbar_practice" model="website.menu">
            <field name="name">Daily Practice</field>
            <field name="url">/my/practice</field>
            <field name="parent_id" ref="language_portal.menu_practice_group"/>
            <field name="sequence">10</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

        <!-- My Dashboard — child of Tools group (language_portal) -->
        <record id="menu_navbar_dashboard" model="website.menu">
            <field name="name">My Dashboard</field>
            <field name="url">/my/dashboard</field>
            <field name="parent_id" ref="language_portal.menu_tools_group"/>
            <field name="sequence">10</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

        <!-- Language Preferences — child of Tools group, M29 added so users
             can find /my/profile (where Polish appears under learning_languages) -->
        <record id="menu_navbar_profile" model="website.menu">
            <field name="name">Language Preferences</field>
            <field name="url">/my/profile</field>
            <field name="parent_id" ref="language_portal.menu_tools_group"/>
            <field name="sequence">15</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

        <!-- Leaderboard — child of Tools group (language_portal) -->
        <record id="menu_navbar_leaderboard" model="website.menu">
            <field name="name">Leaderboard</field>
            <field name="url">/my/leaderboard</field>
            <field name="parent_id" ref="language_portal.menu_tools_group"/>
            <field name="sequence">20</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

        <!-- XP Shop — child of Tools group (language_portal) -->
        <record id="menu_navbar_shop" model="website.menu">
            <field name="name">XP Shop</field>
            <field name="url">/my/shop</field>
            <field name="parent_id" ref="language_portal.menu_tools_group"/>
            <field name="sequence">40</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

        <!-- My Inventory — child of Tools group (language_portal) -->
        <record id="menu_navbar_inventory" model="website.menu">
            <field name="name">My Inventory</field>
            <field name="url">/my/inventory</field>
            <field name="parent_id" ref="language_portal.menu_tools_group"/>
            <field name="sequence">50</field>
            <field name="user_logged">True</field>
            <field name="user_not_logged">False</field>
        </record>

    </data>
</odoo>
