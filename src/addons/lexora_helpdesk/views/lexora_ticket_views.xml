<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_lexora_ticket_list" model="ir.ui.view">
        <field name="name">lexora.ticket.list</field>
        <field name="model">lexora.ticket</field>
        <field name="arch" type="xml">
            <list string="Support Tickets" decoration-info="state == 'new'">
                <field name="name"/>
                <field name="user_id"/>
                <field name="state"/>
                <field name="create_date" string="Submitted"/>
            </list>
        </field>
    </record>

    <record id="view_lexora_ticket_form" model="ir.ui.view">
        <field name="name">lexora.ticket.form</field>
        <field name="model">lexora.ticket</field>
        <field name="arch" type="xml">
            <form string="Support Ticket">
                <header>
                    <button name="action_close" type="object" string="Close Ticket"
                            invisible="state == 'closed'" class="btn-secondary"/>
                    <button name="action_reopen" type="object" string="Reopen"
                            invisible="state == 'new'" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,closed"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" placeholder="Subject"/>
                        <field name="user_id"/>
                    </group>
                    <group>
                        <field name="description" nolabel="1" placeholder="Message"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_lexora_ticket_search" model="ir.ui.view">
        <field name="name">lexora.ticket.search</field>
        <field name="model">lexora.ticket</field>
        <field name="arch" type="xml">
            <search string="Support Tickets">
                <field name="name"/>
                <field name="user_id"/>
                <filter name="new" string="New" domain="[('state','=','new')]"/>
                <filter name="closed" string="Closed" domain="[('state','=','closed')]"/>
                <group expand="1" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_lexora_ticket" model="ir.actions.act_window">
        <field name="name">Support Tickets</field>
        <field name="res_model">lexora.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_lexora_ticket_search"/>
    </record>

    <!-- Top-level backend menu -->
    <menuitem id="menu_lexora_helpdesk_root"
              name="Helpdesk"
              sequence="95"
              groups="base.group_user"/>

    <menuitem id="menu_lexora_ticket"
              name="Support Tickets"
              parent="menu_lexora_helpdesk_root"
              action="action_lexora_ticket"
              sequence="10"/>

</odoo>
