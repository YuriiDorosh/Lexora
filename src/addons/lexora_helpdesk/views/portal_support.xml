<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         /support  — ticket submission form
         Two fields only: Subject + Message.
    ================================================================ -->
    <template id="portal_support_form" name="Lexora Support">
        <t t-call="website.layout">
            <t t-set="head">
                <style>
                    .lxhd-hero {
                        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
                        padding: 4rem 0;
                    }
                    .lxhd-hero h1 { color: #fff; font-weight: 700; }
                    .lxhd-hero .lead { color: rgba(255,255,255,0.65); }
                    .lxhd-card {
                        border: none;
                        border-radius: 1rem;
                        box-shadow: 0 8px 32px rgba(0,0,0,0.12);
                    }
                    .lxhd-card .form-control:focus {
                        border-color: #6366f1;
                        box-shadow: 0 0 0 0.2rem rgba(99,102,241,0.25);
                    }
                    .lxhd-submit {
                        background: linear-gradient(90deg, #4f46e5, #7c3aed);
                        border: none;
                        font-weight: 600;
                        letter-spacing: 0.02em;
                    }
                    .lxhd-submit:hover { opacity: 0.9; }
                </style>
            </t>
            <div id="wrap">

                <!-- Hero strip -->
                <section class="lxhd-hero text-center">
                    <div class="container">
                        <h1 class="display-5 mb-2">Support</h1>
                        <p class="lead mb-0">
                            Our AI replies instantly — human backup is available if needed.
                        </p>
                    </div>
                </section>

                <!-- Form -->
                <section class="py-5 bg-light">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-7 col-md-9">
                                <div class="card lxhd-card">
                                    <div class="card-body p-4 p-md-5">

                                        <t t-if="error">
                                            <div class="alert alert-danger rounded-3" role="alert">
                                                <t t-esc="error"/>
                                            </div>
                                        </t>

                                        <form action="/support/submit" method="post"
                                              novalidate="novalidate">
                                            <input type="hidden" name="csrf_token"
                                                   t-att-value="request.csrf_token()"/>

                                            <div class="mb-4">
                                                <label for="lxhd_name"
                                                       class="form-label fw-semibold">
                                                    Subject
                                                </label>
                                                <input
                                                    type="text"
                                                    id="lxhd_name"
                                                    name="name"
                                                    class="form-control form-control-lg rounded-3"
                                                    placeholder="What can we help you with?"
                                                    required="required"
                                                    t-att-value="name or ''"/>
                                            </div>

                                            <div class="mb-4">
                                                <label for="lxhd_desc"
                                                       class="form-label fw-semibold">
                                                    Message
                                                </label>
                                                <textarea
                                                    id="lxhd_desc"
                                                    name="description"
                                                    class="form-control rounded-3"
                                                    rows="7"
                                                    placeholder="Please describe your issue in detail…"
                                                    required="required"><t t-esc="description or ''"/></textarea>
                                            </div>

                                            <div class="d-grid">
                                                <button type="submit"
                                                        class="btn btn-primary lxhd-submit btn-lg">
                                                    Send Message &#8594;
                                                </button>
                                            </div>
                                        </form>

                                    </div>
                                </div>

                                <p class="text-center text-muted mt-3" style="font-size:.85rem;">
                                    Our AI assistant will respond immediately in the ticket thread.
                                    No account required to submit.
                                </p>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </t>
    </template>

    <!-- ================================================================
         /support  — confirmation page after submission
    ================================================================ -->
    <template id="portal_support_thanks" name="Lexora Support — Thank You">
        <t t-call="website.layout">
            <div id="wrap">
                <section style="
                    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
                    min-height: 70vh;
                    display: flex;
                    align-items: center;
                ">
                    <div class="container py-5 text-center">
                        <div class="row justify-content-center">
                            <div class="col-lg-6 col-md-8">
                                <div style="font-size: 4rem; line-height: 1; margin-bottom: 1.5rem;">
                                    &#10003;
                                </div>
                                <h2 class="fw-bold mb-3" style="color:#fff;">
                                    Ticket Submitted!
                                </h2>
                                <p class="mb-4" style="color:rgba(255,255,255,0.7); font-size:1.1rem;">
                                    Our AI is generating a reply right now.
                                    You'll see it in the ticket chatter within seconds.
                                </p>
                                <a href="/support"
                                   class="btn btn-outline-light btn-lg px-4">
                                    Submit Another Ticket
                                </a>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

</odoo>
