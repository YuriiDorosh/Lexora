<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_word_of_day" model="ir.cron">
            <field name="name">Lexora: Select Word of the Day</field>
            <field name="model_id" ref="model_language_word_of_day"/>
            <field name="state">code</field>
            <field name="code">model._pick_word_of_day()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>
