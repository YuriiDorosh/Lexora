<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================
             language.entry record-level rules (SPEC §5, ADR-004)

             Two rules are combined with OR logic (Odoo default):
               read:   owner's own entries  OR  any shared entry
               write / create / unlink:  owner's own entries only
        ============================================================ -->

        <!-- Full CRUD for own entries -->
        <record id="rule_entry_owner_full" model="ir.rule">
            <field name="name">Entry: owner full access</field>
            <field name="model_id" ref="model_language_entry"/>
            <field name="groups" eval="[(4, ref('language_security.group_language_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="domain_force">[('owner_id', '=', user.id)]</field>
        </record>

        <!-- Read-only access to shared entries from any owner -->
        <record id="rule_entry_shared_read" model="ir.rule">
            <field name="name">Entry: shared read-only access</field>
            <field name="model_id" ref="model_language_entry"/>
            <field name="groups" eval="[(4, ref('language_security.group_language_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[('is_shared', '=', True)]</field>
        </record>

        <!-- ============================================================
             language.user.profile — users see and manage only their own
        ============================================================ -->

        <record id="rule_user_profile_own" model="ir.rule">
            <field name="name">User Profile: own record only</field>
            <field name="model_id" ref="model_language_user_profile"/>
            <field name="groups" eval="[(4, ref('language_security.group_language_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
        </record>

        <!-- ============================================================
             language.media.link — via entry ownership
             Users can CRUD links attached to their own entries.
        ============================================================ -->

        <record id="rule_media_link_own_entry" model="ir.rule">
            <field name="name">Media Link: own entry only</field>
            <field name="model_id" ref="model_language_media_link"/>
            <field name="groups" eval="[(4, ref('language_security.group_language_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="domain_force">[('entry_id.owner_id', '=', user.id)]</field>
        </record>

    </data>
</odoo>
