<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Portal home — add "My Vocabulary" widget + Lexora quick links
    ============================================================ -->
    <template id="portal_my_home_vocabulary" inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">My Vocabulary</t>
                <t t-set="url" t-value="'/my/vocabulary'"/>
                <t t-set="count" t-value="entry_count"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_home_lexora_quicklinks" inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <div class="card mb-3">
                <div class="card-body py-3">
                    <h5 class="card-title mb-2">Lexora — quick actions</h5>
                    <p class="card-text text-muted small mb-2">
                        Build your vocabulary, browse shared entries, and set which
                        languages you are learning so translations happen automatically.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="/my/vocabulary" class="btn btn-sm btn-primary">My Vocabulary</a>
                        <a href="/my/vocabulary/new" class="btn btn-sm btn-outline-primary">+ Add entry</a>
                        <a href="/my/vocabulary/shared" class="btn btn-sm btn-outline-secondary">Browse shared</a>
                        <a href="/my/profile" class="btn btn-sm btn-outline-secondary">Language preferences</a>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ============================================================
         Vocabulary list  /my/vocabulary
    ============================================================ -->
    <template id="portal_vocabulary_list" name="My Vocabulary">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Vocabulary</t>
            </t>
            <div class="container mt-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3>My Vocabulary <span class="text-muted fs-6 fw-normal">(<t t-esc="entry_count"/> entries)</span></h3>
                    <div>
                        <a href="/my/vocabulary/new" class="btn btn-primary btn-sm">+ Add Entry</a>
                        <a href="/my/vocabulary/shared" class="btn btn-outline-secondary btn-sm ms-2">Browse Shared</a>
                    </div>
                </div>

                <t t-if="not entries">
                    <div class="text-center py-5 text-muted">
                        <p class="mb-2">Your vocabulary list is empty.</p>
                        <a href="/my/vocabulary/new" class="btn btn-primary btn-sm">Add your first entry</a>
                    </div>
                </t>

                <t t-if="entries">
                    <table class="table table-hover table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Text</th>
                                <th>Type</th>
                                <th>Language</th>
                                <th>Translations</th>
                                <th>Flags</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="entries" t-as="entry">
                                <tr>
                                    <td>
                                        <a t-att-href="'/my/vocabulary/%d' % entry.id" class="fw-medium text-decoration-none">
                                            <t t-esc="entry.source_text"/>
                                        </a>
                                    </td>
                                    <td><span class="badge bg-secondary"><t t-esc="entry.type"/></span></td>
                                    <td>
                                        <span class="badge bg-primary">
                                            <t t-esc="lang_names.get(entry.source_language, entry.source_language)"/>
                                        </span>
                                    </td>
                                    <td>
                                        <t t-if="entry.pvp_eligible">
                                            <span class="badge bg-success" title="Has completed translation — PvP eligible">✓ translated</span>
                                        </t>
                                        <t t-elif="entry.translation_ids">
                                            <span class="badge bg-warning text-dark">pending…</span>
                                        </t>
                                        <t t-else="">
                                            <span class="text-muted small">—</span>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="entry.is_shared">
                                            <span class="badge bg-info">shared</span>
                                        </t>
                                        <t t-if="entry.status == 'archived'">
                                            <span class="badge bg-secondary">archived</span>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <t t-call="portal.pager"/>
                </t>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Entry detail  /my/vocabulary/<id>
    ============================================================ -->
    <template id="portal_vocabulary_detail" name="Entry Detail">
        <t t-call="portal.portal_layout">
            <div class="container mt-4" style="max-width: 800px;">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/my/vocabulary">My Vocabulary</a></li>
                        <li class="breadcrumb-item active" aria-current="page"><t t-esc="entry.source_text"/></li>
                    </ol>
                </nav>

                <div class="card mt-3 shadow-sm">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                        <h4 class="mb-0 fw-bold"><t t-esc="entry.source_text"/></h4>
                        <div class="d-flex flex-wrap gap-1 justify-content-end">
                            <span class="badge bg-secondary text-capitalize"><t t-esc="entry.type"/></span>
                            <span class="badge bg-primary">
                                <t t-esc="lang_names.get(entry.source_language, entry.source_language)"/>
                            </span>
                            <t t-if="entry.pvp_eligible">
                                <span class="badge bg-success" title="Has at least one completed translation — eligible for PvP battles">⚡ PvP ready</span>
                            </t>
                            <t t-if="entry.is_shared">
                                <span class="badge bg-info">shared</span>
                            </t>
                            <t t-if="entry.status == 'archived'">
                                <span class="badge bg-warning text-dark">archived</span>
                            </t>
                        </div>
                    </div>
                    <div class="card-body px-4 py-3">

                        <!-- ── Actions ── -->
                        <div class="d-flex flex-wrap gap-2 mb-3 pb-3 border-bottom">
                            <form t-att-action="'/my/vocabulary/%d/share' % entry.id" method="post" class="d-inline">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-sm btn-outline-info">
                                    <t t-if="entry.is_shared">Unshare</t>
                                    <t t-else="">Share with community</t>
                                </button>
                            </form>
                            <form t-att-action="'/my/vocabulary/%d/archive' % entry.id" method="post" class="d-inline">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                    <t t-if="entry.status == 'active'">Archive</t>
                                    <t t-else="">Restore</t>
                                </button>
                            </form>
                            <a href="/my/vocabulary" class="btn btn-sm btn-link text-muted ms-auto">← Back to list</a>
                        </div>

                        <!-- ── Translations ──
                             Self-contained: all logic computed from live ORM data.
                             Does NOT depend on any controller-passed variable so this
                             renders correctly even before the server restarts to load
                             the updated Python controller.
                        -->
                        <div class="mb-3">
                            <h6 class="text-uppercase text-muted small fw-bold mb-2">Translations</h6>

                            <!-- Compute which target-language codes already have records. -->
                            <t t-set="_existing_codes" t-value="entry.translation_ids.mapped('target_language')"/>

                            <!-- Existing translation records -->
                            <t t-if="entry.translation_ids">
                                <table class="table table-sm table-borderless mb-1">
                                    <tbody>
                                        <t t-foreach="entry.translation_ids" t-as="tr">
                                            <tr class="align-middle">
                                                <td style="width:110px">
                                                    <span class="badge bg-secondary">
                                                        <t t-esc="lang_names.get(tr.target_language, tr.target_language)"/>
                                                    </span>
                                                </td>
                                                <td>
                                                    <t t-if="tr.status == 'completed'">
                                                        <strong class="fs-6"><t t-esc="tr.translated_text"/></strong>
                                                    </t>
                                                    <t t-if="tr.status in ('processing', 'pending')">
                                                        <span class="text-muted">
                                                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"/>
                                                            <t t-if="tr.status == 'processing'">Translating…</t>
                                                            <t t-else="">Queued…</t>
                                                        </span>
                                                    </t>
                                                    <t t-if="tr.status == 'failed'">
                                                        <span class="text-danger small">
                                                            Translation failed
                                                            <t t-if="tr.error_message"> — <t t-esc="tr.error_message"/></t>
                                                        </span>
                                                    </t>
                                                </td>
                                                <td style="width:90px" class="text-end">
                                                    <t t-if="tr.status == 'failed'">
                                                        <form t-att-action="'/my/vocabulary/%d/retry_translation/%d' % (entry.id, tr.id)"
                                                              method="post" class="d-inline">
                                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                            <button type="submit" class="btn btn-xs btn-outline-warning py-0 px-2"
                                                                    style="font-size:0.75rem">Retry</button>
                                                        </form>
                                                    </t>
                                                    <t t-if="tr.status == 'completed'">
                                                        <span class="badge bg-success me-1">✓</span>
                                                        <button type="button"
                                                                class="btn btn-xs btn-outline-secondary py-0 px-1"
                                                                style="font-size:0.75rem"
                                                                t-att-data-target="'edit-tr-%d' % tr.id"
                                                                onclick="(function(b){var r=document.getElementById(b.dataset.target);if(r){r.classList.toggle('d-none');}})(this)"
                                                                title="Edit translation">✎</button>
                                                    </t>
                                                </td>
                                            </tr>
                                            <!-- Inline edit row (hidden until pencil clicked) -->
                                            <t t-if="tr.status == 'completed'">
                                                <tr t-att-id="'edit-tr-%d' % tr.id" class="d-none bg-light">
                                                    <td colspan="3" class="py-2 px-3">
                                                        <form t-att-action="'/my/translation/update/%d' % tr.id" method="post">
                                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                            <textarea name="translated_text"
                                                                      class="form-control form-control-sm mb-2"
                                                                      rows="2"
                                                                      style="font-size:0.9rem"><t t-esc="tr.translated_text"/></textarea>
                                                            <div class="d-flex gap-2">
                                                                <button type="submit" class="btn btn-sm btn-primary">Save</button>
                                                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                                                        t-att-data-target="'edit-tr-%d' % tr.id"
                                                                        onclick="(function(b){var r=document.getElementById(b.dataset.target);if(r){r.classList.add('d-none');}})(this)">Cancel</button>
                                                            </div>
                                                        </form>
                                                    </td>
                                                </tr>
                                            </t>
                                        </t>
                                    </tbody>
                                </table>
                            </t>

                            <!-- "Translate to X" buttons for languages without a record.
                                 Computed inline — no controller variable dependency.      -->
                            <div class="d-flex flex-wrap gap-2 mt-1">
                                <t t-foreach="[('en','English'),('uk','Ukrainian'),('el','Greek')]" t-as="_lng">
                                    <t t-if="_lng[0] != entry.source_language and _lng[0] not in _existing_codes">
                                        <form t-att-action="'/my/vocabulary/%d/translate/%s' % (entry.id, _lng[0])"
                                              method="post" class="d-inline">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                + Translate to <t t-esc="_lng[1]"/>
                                            </button>
                                        </form>
                                    </t>
                                </t>
                            </div>

                            <!-- Empty state — only when no translation records exist -->
                            <t t-if="not entry.translation_ids">
                                <p class="text-muted small mb-0 mt-1">
                                    No translations yet. Use the buttons above to request one,
                                    or configure your
                                    <a href="/my/profile">learning languages</a>
                                    for automatic translation on save.
                                </p>
                            </t>
                        </div>

                        <hr class="my-3"/>

                        <!-- ── Enrichment section injected here by language_enrichment module ── -->
                        <!-- (portal_enrichment.xml targets the media_links block below) -->

                        <!-- ── Media links ── -->
                        <t t-if="entry.media_links">
                            <h6 class="text-uppercase text-muted small fw-bold mb-2">Media Links</h6>
                            <ul class="list-unstyled mb-0">
                                <t t-foreach="entry.media_links" t-as="link">
                                    <li class="mb-1">
                                        <a t-att-href="link.url" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                                            <t t-esc="link.title or link.url"/>
                                        </a>
                                        <t t-if="link.description">
                                            <span class="text-muted small ms-1">— <t t-esc="link.description"/></span>
                                        </t>
                                    </li>
                                </t>
                            </ul>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Add entry form  /my/vocabulary/new
    ============================================================ -->
    <template id="portal_vocabulary_new" name="Add Entry">
        <t t-call="portal.portal_layout">
            <div class="container mt-4" style="max-width: 600px;">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/my/vocabulary">My Vocabulary</a></li>
                        <li class="breadcrumb-item active">Add Entry</li>
                    </ol>
                </nav>

                <div class="card mt-3">
                    <div class="card-header"><h5 class="mb-0">Add New Entry</h5></div>
                    <div class="card-body">
                        <t t-if="error">
                            <div class="alert alert-danger"><t t-esc="error"/></div>
                        </t>
                        <form method="post" action="/my/vocabulary/new">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <div class="mb-3">
                                <label for="source_text" class="form-label fw-bold">Text</label>
                                <input type="text"
                                       id="source_text"
                                       name="source_text"
                                       class="form-control"
                                       t-att-value="source_text"
                                       placeholder="Word, phrase or sentence…"
                                       autocomplete="off"
                                       required="required"/>
                                <div class="form-text">
                                    Language is auto-detected as you type. You can correct it below.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="source_language" class="form-label fw-bold">Language</label>
                                <select id="source_language" name="source_language" class="form-select" required="required">
                                    <option value="">-- select language --</option>
                                    <option value="en" t-att-selected="'selected' if source_language == 'en' else None">English</option>
                                    <option value="uk" t-att-selected="'selected' if source_language == 'uk' else None">Ukrainian</option>
                                    <option value="el" t-att-selected="'selected' if source_language == 'el' else None">Greek</option>
                                </select>
                                <div id="detection_hint" class="form-text text-muted"></div>
                            </div>

                            <div class="mb-3">
                                <label for="entry_type" class="form-label fw-bold">Type</label>
                                <select id="entry_type" name="entry_type" class="form-select">
                                    <option value="word" t-att-selected="'selected' if entry_type == 'word' else None">Word</option>
                                    <option value="phrase" t-att-selected="'selected' if entry_type == 'phrase' else None">Phrase</option>
                                    <option value="sentence" t-att-selected="'selected' if entry_type == 'sentence' else None">Sentence</option>
                                    <option value="collocation" t-att-selected="'selected' if entry_type == 'collocation' else None">Collocation</option>
                                </select>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Save</button>
                                <a href="/my/vocabulary" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Language auto-detection via AJAX -->
            <script type="text/javascript">
                (function () {
                    var textInput = document.getElementById('source_text');
                    var langSelect = document.getElementById('source_language');
                    var hint = document.getElementById('detection_hint');
                    var debounceTimer = null;

                    if (!textInput) return;

                    textInput.addEventListener('input', function () {
                        clearTimeout(debounceTimer);
                        var text = textInput.value;
                        if (!text || text.length &lt; 4) {
                            hint.textContent = '';
                            return;
                        }
                        debounceTimer = setTimeout(function () {
                            fetch('/my/vocabulary/detect_language', {
                                method: 'POST',
                                headers: {'Content-Type': 'application/json'},
                                body: JSON.stringify({
                                    jsonrpc: '2.0', method: 'call', id: 1,
                                    params: { text: text }
                                })
                            })
                            .then(function (r) { return r.json(); })
                            .then(function (data) {
                                var lang = data.result;
                                if (lang) {
                                    langSelect.value = lang;
                                    hint.textContent = 'Auto-detected: ' + lang + ' (you can change it)';
                                    hint.className = 'form-text text-success';
                                } else {
                                    hint.textContent = 'Could not detect language automatically.';
                                    hint.className = 'form-text text-muted';
                                }
                            })
                            .catch(function () {});
                        }, 500);
                    });
                }());
            </script>
        </t>
    </template>

    <!-- ============================================================
         Language preferences  /my/profile
    ============================================================ -->
    <template id="portal_profile" name="Language Preferences">
        <t t-call="portal.portal_layout">
            <div class="container mt-4" style="max-width: 700px;">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/my">My Account</a></li>
                        <li class="breadcrumb-item active">Language Preferences</li>
                    </ol>
                </nav>

                <div class="card mt-3 shadow-sm">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold">Language Preferences</h5>
                        <small class="text-muted">Configure your learning languages to enable
                            automatic translations on every new entry.</small>
                    </div>
                    <div class="card-body px-4 py-3">
                        <t t-if="error">
                            <div class="alert alert-danger"><t t-esc="error"/></div>
                        </t>
                        <t t-if="saved and not error">
                            <div class="alert alert-success py-2">
                                Preferences saved. New entries will be translated into your
                                selected learning languages automatically.
                            </div>
                        </t>

                        <form method="post" action="/my/profile">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                            <div class="mb-3">
                                <label for="native_language" class="form-label fw-bold">Native language</label>
                                <select id="native_language" name="native_language" class="form-select">
                                    <option value="">— not set —</option>
                                    <t t-foreach="[('en','English'),('uk','Ukrainian'),('el','Greek')]" t-as="opt">
                                        <option t-att-value="opt[0]"
                                                t-att-selected="'selected' if profile.native_language == opt[0] else None">
                                            <t t-esc="opt[1]"/>
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Learning languages</label>
                                <div class="form-text mb-1">
                                    Pick every language you want automatic translations into.
                                    Every new entry you add is translated into each of these.
                                </div>
                                <t t-set="profile_codes" t-value="profile.learning_languages.mapped('code')"/>
                                <t t-foreach="all_langs" t-as="lrec">
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="learning_languages"
                                               t-att-id="'learn_%s' % lrec.code"
                                               t-att-value="lrec.code"
                                               t-att-checked="'checked' if lrec.code in profile_codes else None"/>
                                        <label class="form-check-label" t-att-for="'learn_%s' % lrec.code">
                                            <t t-esc="lang_names.get(lrec.code, lrec.name)"/>
                                        </label>
                                    </div>
                                </t>
                            </div>

                            <div class="mb-3">
                                <label for="default_source_language" class="form-label fw-bold">
                                    Default source language
                                </label>
                                <select id="default_source_language" name="default_source_language" class="form-select">
                                    <option value="">— not set —</option>
                                    <t t-foreach="[('en','English'),('uk','Ukrainian'),('el','Greek')]" t-as="opt">
                                        <option t-att-value="opt[0]"
                                                t-att-selected="'selected' if profile.default_source_language == opt[0] else None">
                                            <t t-esc="opt[1]"/>
                                        </option>
                                    </t>
                                </select>
                                <div class="form-text">
                                    Used as a fallback when auto-detection of a typed entry is ambiguous.
                                </div>
                            </div>

                            <div class="mb-3 form-check">
                                <input type="checkbox" id="is_shared_list" name="is_shared_list"
                                       value="1" class="form-check-input"
                                       t-att-checked="'checked' if profile.is_shared_list else None"/>
                                <label for="is_shared_list" class="form-check-label">
                                    Share my whole vocabulary list with the community
                                </label>
                                <div class="form-text">
                                    Off by default. You can also mark individual entries as shared
                                    from their detail page.
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Save preferences</button>
                                <a href="/my/vocabulary" class="btn btn-outline-secondary">Back to vocabulary</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Shared vocabulary  /my/vocabulary/shared
    ============================================================ -->
    <template id="portal_vocabulary_shared" name="Shared Vocabulary">
        <t t-call="portal.portal_layout">
            <div class="container mt-4">
                <h3>Shared Vocabulary (<t t-esc="entry_count"/> entries)</h3>
                <a href="/my/vocabulary" class="btn btn-outline-secondary btn-sm mb-3">Back to My Vocabulary</a>

                <t t-if="not entries">
                    <p class="text-muted">No shared entries from other users yet.</p>
                </t>

                <t t-if="entries">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Text</th>
                                <th>Type</th>
                                <th>Language</th>
                                <th>Shared by</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="entries" t-as="entry">
                                <tr>
                                    <td><t t-esc="entry.source_text"/></td>
                                    <td><span class="badge bg-secondary"><t t-esc="entry.type"/></span></td>
                                    <td>
                                        <span class="badge bg-primary">
                                            <t t-esc="lang_names.get(entry.source_language, entry.source_language)"/>
                                        </span>
                                    </td>
                                    <td><t t-esc="entry.owner_id.name"/></td>
                                    <td>
                                        <form t-att-action="'/my/vocabulary/%d/copy' % entry.id" method="post" class="d-inline">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Copy to my list</button>
                                        </form>
