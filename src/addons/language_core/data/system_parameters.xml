<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            noupdate="1" so that admin changes are not overwritten on module upgrade.
        -->

        <!-- Minimum number of entries in the practice language before a user
             can start a PvP battle (SPEC §4.12, ADR-010). -->
        <record id="param_pvp_min_entries" model="ir.config_parameter">
            <field name="key">language.pvp.min_entries</field>
            <field name="value">10</field>
        </record>

        <!-- Maximum audio upload size in bytes for user-recorded audio
             (SPEC §4.5, ADR-008).  Default: 10 MB = 10 * 1024 * 1024. -->
        <record id="param_audio_max_upload_bytes" model="ir.config_parameter">
            <field name="key">language.audio.max_upload_bytes</field>
            <field name="value">10485760</field>
        </record>

        <!-- RabbitMQ connection parameters (M3).
             Override these via Settings > Technical > Parameters > System Parameters
             for non-default environments. -->
        <record id="param_rabbitmq_host" model="ir.config_parameter">
            <field name="key">rabbitmq.host</field>
            <field name="value">rabbitmq</field>
        </record>
        <record id="param_rabbitmq_port" model="ir.config_parameter">
            <field name="key">rabbitmq.port</field>
            <field name="value">5672</field>
        </record>
        <record id="param_rabbitmq_vhost" model="ir.config_parameter">
            <field name="key">rabbitmq.vhost</field>
            <field name="value">/</field>
        </record>
        <record id="param_rabbitmq_user" model="ir.config_parameter">
            <field name="key">rabbitmq.user</field>
            <field name="value">guest</field>
        </record>
        <record id="param_rabbitmq_password" model="ir.config_parameter">
            <field name="key">rabbitmq.password</field>
            <field name="value">guest</field>
        </record>

    </data>
</odoo>
