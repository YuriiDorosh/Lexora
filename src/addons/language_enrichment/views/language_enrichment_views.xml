<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         List view
    ============================================================ -->
    <record id="view_language_enrichment_list" model="ir.ui.view">
        <field name="name">language.enrichment.list</field>
        <field name="model">language.enrichment</field>
        <field name="arch" type="xml">
            <list string="Enrichments"
                  decoration-success="status == 'completed'"
                  decoration-warning="status == 'processing'"
                  decoration-danger="status == 'failed'"
                  decoration-muted="status == 'pending'">
                <field name="entry_id"/>
                <field name="language"/>
                <field name="status"/>
                <field name="job_id"/>
                <field name="error_message" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         Form view
    ============================================================ -->
    <record id="view_language_enrichment_form" model="ir.ui.view">
        <field name="name">language.enrichment.form</field>
        <field name="model">language.enrichment</field>
        <field name="arch" type="xml">
            <form string="Enrichment">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,processing,completed,failed"/>
                    <button name="action_retry" string="Retry"
                            type="object" class="btn-warning"
                            invisible="status not in ('failed', 'pending')"/>
                </header>
                <sheet>
                    <group>
                        <field name="entry_id"/>
                        <field name="language"/>
                        <field name="job_id"/>
                        <field name="error_message" invisible="status != 'failed'"/>
                    </group>
                    <group string="Results" invisible="status != 'completed'">
                        <field name="synonyms"/>
                        <field name="antonyms"/>
                        <field name="example_sentences"/>
                        <field name="explanation"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         Action + menu
    ============================================================ -->
    <record id="action_language_enrichment" model="ir.actions.act_window">
        <field name="name">Enrichments</field>
        <field name="res_model">language.enrichment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lexora_enrichments"
              name="Enrichments"
              parent="language_words.menu_lexora_root"
              action="action_language_enrichment"
              sequence="40"/>

</odoo>
