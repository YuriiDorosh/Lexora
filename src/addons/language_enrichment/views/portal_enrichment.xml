<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Inject the enrichment section into the entry detail page.
        language_words.portal_vocabulary_detail is defined in language_words.
        We add an "Enrich" button and results panel between Translations and Media Links.
    -->
    <template id="portal_entry_enrichment_section"
              inherit_id="language_words.portal_vocabulary_detail"
              name="Entry Detail — Enrichment Section">

        <!-- Insert enrichment block just before the Media Links section -->
        <xpath expr="//t[@t-if='entry.media_links']" position="before">

            <!-- Enrich trigger button -->
            <div class="mb-3">
                <form t-att-action="'/my/vocabulary/%d/enrich' % entry.id" method="post"
                      class="d-inline">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <button type="submit" class="btn btn-sm btn-outline-primary">
                        Enrich with AI
                    </button>
                </form>
                <span class="text-muted small ms-2">
                    Generates synonyms, antonyms, example sentences, and explanation
                    using a local LLM.
                </span>
            </div>

            <!-- Enrichment results -->
            <t t-if="entry.enrichment_ids">
                <h6>Enrichments</h6>
                <t t-foreach="entry.enrichment_ids" t-as="en">
                    <div class="card mb-2">
                        <div class="card-header d-flex justify-content-between align-items-center py-1 px-2">
                            <span>
                                <span class="badge bg-secondary me-1"><t t-esc="en.language"/></span>
                                <t t-if="en.status == 'completed'">
                                    <span class="badge bg-success">done</span>
                                </t>
                                <t t-if="en.status == 'processing'">
                                    <span class="badge bg-warning text-dark">
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"/>
                                        processing
                                    </span>
                                </t>
                                <t t-if="en.status == 'pending'">
                                    <span class="badge bg-secondary">pending</span>
                                </t>
                                <t t-if="en.status == 'failed'">
                                    <span class="badge bg-danger">failed</span>
                                </t>
                            </span>
                            <t t-if="en.status == 'failed'">
                                <form t-att-action="'/my/vocabulary/%d/retry_enrichment/%d' % (entry.id, en.id)"
                                      method="post" class="d-inline">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button type="submit" class="btn btn-sm btn-outline-warning py-0">
                                        Retry
                                    </button>
                                </form>
                            </t>
                        </div>

                        <t t-if="en.status == 'completed'">
                            <div class="card-body py-2 px-3">
                                <t t-set="syns" t-value="en._synonyms_list()"/>
                                <t t-set="ants" t-value="en._antonyms_list()"/>
                                <t t-set="exs"  t-value="en._example_sentences_list()"/>

                                <t t-if="syns">
                                    <p class="mb-1">
                                        <strong>Synonyms:</strong>
                                        <t t-foreach="syns" t-as="s">
                                            <span class="badge bg-light text-dark border me-1"><t t-esc="s"/></span>
                                        </t>
                                    </p>
                                </t>
                                <t t-if="ants">
                                    <p class="mb-1">
                                        <strong>Antonyms:</strong>
                                        <t t-foreach="ants" t-as="a">
                                            <span class="badge bg-light text-dark border me-1"><t t-esc="a"/></span>
                                        </t>
                                    </p>
                                </t>
                                <t t-if="en.explanation">
                                    <p class="mb-1">
                                        <strong>Explanation:</strong>
                                        <t t-esc="en.explanation"/>
                                    </p>
                                </t>
                                <t t-if="exs">
                                    <p class="mb-1"><strong>Examples:</strong></p>
                                    <ol class="mb-0">
                                        <t t-foreach="exs" t-as="ex">
                                            <li><t t-esc="ex"/></li>
                                        </t>
                                    </ol>
                                </t>
                            </div>
                        </t>

                        <t t-if="en.status == 'failed' and en.error_message">
                            <div class="card-body py-1 px-3">
                                <span class="text-danger small"><t t-esc="en.error_message"/></span>
                            </div>
                        </t>
                    </div>
                </t>
            </t>

        </xpath>
    </template>
</odoo>
